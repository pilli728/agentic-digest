---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date?: string;
}

const { title, date } = Astro.props;
---

<BaseLayout title={title}>
  <header class="digest-header">
    <a href="/" class="back-link">← Back to archive</a>
    {date && <p class="digest-date">{date}</p>}
  </header>

  <main class="digest-content">
    <slot />
  </main>

  <footer class="digest-footer">
    <p>Generated by <strong>Agentic Edge Digest</strong> • Filtered from 20+ sources using Claude</p>
  </footer>

  <style>
    .digest-header {
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .back-link {
      display: inline-block;
      margin-bottom: 0.5rem;
      font-size: 0.9em;
    }

    .digest-date {
      font-size: 0.95em;
      color: #888;
      margin: 0.5rem 0 0 0;
    }

    .digest-content {
      margin-bottom: 4rem;
    }

    .digest-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border);
      text-align: center;
      font-size: 0.9em;
      color: #888;
    }

    strong {
      font-weight: 600;
    }
  </style>
</BaseLayout>
