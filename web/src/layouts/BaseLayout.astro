---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📡</text></svg>" />
    <title>{title} | Agentic Edge</title>
    <meta name="description" content={description} />
    <meta name="api-url" content={import.meta.env.PUBLIC_API_URL || 'http://localhost:8000'} />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Inter:wght@400;500;600&display=swap');

      :root {
        --color-bg: #ffffff;
        --color-fg: #1a1a1a;
        --color-border: #e5e5e5;
        --color-accent: #0066cc;
        --color-tier-1: #dc2626;
        --color-tier-2: #f59e0b;
        --color-tier-3: #2563eb;
        --color-tier-4: #6b7280;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #0f0f0f;
          --color-fg: #ffffff;
          --color-border: #2a2a2a;
          --color-accent: #60a5fa;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Inter', sans-serif;
        background: var(--color-bg);
        color: var(--color-fg);
        line-height: 1.6;
      }

      h1, h2, h3 {
        font-family: 'Merriweather', serif;
        font-weight: 700;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
      }

      h1 { font-size: 2.5em; }
      h2 { font-size: 1.8em; }
      h3 { font-size: 1.3em; }

      a {
        color: var(--color-accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      code {
        background: rgba(0, 102, 204, 0.1);
        padding: 0.2em 0.4em;
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-brand">⚡ Agentic Edge</a>
      <div class="nav-links">
        <a href="/archive">Archive</a>
        <a href="/pro">Pro</a>
        <a href="/login" class="nav-signin" id="nav-signin">Sign in</a>
        <span class="nav-user" id="nav-user" style="display:none"></span>
      </div>
    </nav>

    <div class="container">
      <slot />
    </div>

    <style>
      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem 2rem;
        font-size: 0.9em;
      }
      .nav-brand { font-weight: 700; text-decoration: none; color: var(--color-fg); }
      .nav-links { display: flex; gap: 1.5rem; align-items: center; }
      .nav-links a { text-decoration: none; color: #666; }
      .nav-links a:hover { color: var(--color-fg); }
      .nav-signin { background: #7c3aed; color: white !important; padding: 0.4rem 1rem; border-radius: 6px; font-weight: 500; }
      .nav-signin:hover { background: #6d28d9; }
      .nav-user { font-size: 0.85em; color: #7c3aed; font-weight: 500; }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem 2rem;
      }

      @media (max-width: 768px) {
        .site-nav { padding: 1rem; }
        .container { padding: 0 1rem 1rem; }
      }
    </style>

    <script is:inline>
      // Global API URL from meta tag
      window.API_URL = document.querySelector('meta[name="api-url"]')?.content || 'http://localhost:8000';

      // Check login state
      const sid = localStorage.getItem('ae_session');
      const email = localStorage.getItem('ae_email');
      if (sid && email) {
        const signIn = document.getElementById('nav-signin');
        const userEl = document.getElementById('nav-user');
        if (signIn) signIn.style.display = 'none';
        if (userEl) { userEl.style.display = 'inline'; userEl.textContent = email; }
      }
    </script>
  </body>
</html>
