---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPremium = await getCollection('premium');
const now = new Date();
const premium = allPremium.filter(p => new Date(p.data.date) <= now);
const sorted = premium.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const proContent = sorted.filter(p => p.data.tier === 'pro' || p.data.tier === 'founding');
---

<BaseLayout title="The Vault" description="Playbooks, guides, templates, and tools for AI builders.">
  <!-- Auth gate: not logged in -->
  <div class="auth-gate" id="auth-gate-signin" style="display:none">
    <div class="gate-card">
      <h2>The Vault</h2>
      <p>Playbooks, guides, and tools for serious AI builders.<br><strong>Pro members only.</strong></p>
      <a href="/login" class="gate-btn">Sign in to access</a>
      <p class="gate-sub">Not a Pro member? <a href="/upgrade">Upgrade to Pro</a> · <a href="/">Join free</a></p>
    </div>
  </div>

  <!-- Auth gate: logged in but free tier -->
  <div class="auth-gate" id="auth-gate-upgrade" style="display:none">
    <div class="gate-card">
      <h2>The Vault is a Pro benefit</h2>
      <p>You're signed in, but The Vault requires a Pro membership. Upgrade to access playbooks, guides, templates, and tools.</p>
      <a href="/upgrade" class="gate-btn">Upgrade to Pro — $12/mo</a>
      <p class="gate-sub">Already upgraded? <a href="/login">Sign in again</a> to refresh your session.</p>
    </div>
  </div>

  <!-- Pro content (hidden until auth check) -->
  <div class="pro-content" id="pro-content" style="display:none">
    <header class="pro-header">
      <a href="/" class="back-link">← Back to Agentic Edge</a>
      <h1>The Vault</h1>
      <p>Playbooks, templates, tools, and guides. Everything you need to build with AI agents.</p>
    </header>

    <div class="content-grid">
      {proContent.map(item => (
        <a href={`/pro/${item.slug}`} class={`content-card ${item.data.tier === 'founding' ? 'founding-locked' : ''}`} data-tier={item.data.tier}>
          <div class="card-meta">
            <span class={`tier-badge ${item.data.tier}`}>{item.data.tier === 'founding' ? 'Inner Circle' : 'Pro'}</span>
            <span class="category">{item.data.category}</span>
          </div>
          <h3>{item.data.title}</h3>
          <p>{item.data.description}</p>
        </a>
      ))}
    </div>

    <!-- Templates Section — visible to all Pro, clickable for Inner Circle only -->
    <div class="downloads-section" id="downloads-section">
      <h2>Copy-Paste Templates</h2>
      <p class="downloads-sub">Drop these into your project. Ready to use.</p>

      <div class="downloads-grid">
        <a href="/pro/template/claude-md" class="download-card">
          <span class="dl-icon">📄</span>
          <div>
            <strong>CLAUDE.md</strong>
            <p>Project context for Claude Code. The template every project needs.</p>
          </div>
        </a>
        <a href="/pro/template/agents-md" class="download-card">
          <span class="dl-icon">🤖</span>
          <div>
            <strong>AGENTS.md</strong>
            <p>Constraints, danger zones, verification steps. Not a tech stack list.</p>
          </div>
        </a>
        <a href="/pro/template/react-agent" class="download-card">
          <span class="dl-icon">⚛️</span>
          <div>
            <strong>React Agent CLAUDE.md</strong>
            <p>Next.js + Claude API + Prisma. Pre-configured for agent projects.</p>
          </div>
        </a>
        <a href="/pro/template/python-agent" class="download-card">
          <span class="dl-icon">🐍</span>
          <div>
            <strong>Python Agent CLAUDE.md</strong>
            <p>FastAPI + SQLAlchemy + Claude. Agent rules baked in.</p>
          </div>
        </a>
        <a href="/pro/template/skill-code-review" class="download-card">
          <span class="dl-icon">🔍</span>
          <div>
            <strong>Code Review Skill</strong>
            <p>Security, performance, readability. Drop into .claude/skills/</p>
          </div>
        </a>
        <a href="/pro/template/skill-security-audit" class="download-card">
          <span class="dl-icon">🛡️</span>
          <div>
            <strong>Security Audit Skill</strong>
            <p>OWASP Top 10 checklist as a Claude skill. Catches what you miss.</p>
          </div>
        </a>
        <a href="/pro/template/skill-test-writer" class="download-card">
          <span class="dl-icon">🧪</span>
          <div>
            <strong>Test Writer Skill</strong>
            <p>Edge cases, failure modes, AAA pattern. Makes Claude write real tests.</p>
          </div>
        </a>
        <a href="/pro/template/pre-commit-hook" class="download-card">
          <span class="dl-icon">🪝</span>
          <div>
            <strong>Pre-Commit Hook</strong>
            <p>Tests, lint, typecheck, secret scan. Nothing broken gets committed.</p>
          </div>
        </a>
      </div>
    </div>
  </div>

  <style>
    .pro-header {
      text-align: center;
      padding: 2rem 0;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
    }
    .back-link { display: inline-block; margin-bottom: 1rem; font-size: 0.9em; color: #888; }
    .pro-header h1 { font-size: 2.5em; margin: 0 0 0.5rem; }
    .pro-header p { color: #666; }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .content-card {
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      transition: all 0.2s;
    }
    .content-card:hover {
      border-color: var(--color-accent);
      box-shadow: 0 4px 12px rgba(0,102,204,0.1);
    }

    .card-meta {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .tier-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 12px;
      font-size: 0.75em;
      font-weight: 600;
    }
    .tier-badge.pro { background: rgba(0,102,204,0.1); color: var(--color-accent); }
    .tier-badge.founding { background: rgba(245,158,11,0.1); color: #b45309; }

    .category {
      padding: 0.25rem 0.75rem;
      border-radius: 12px;
      font-size: 0.75em;
      background: rgba(0,0,0,0.05);
      color: #666;
    }

    .content-card h3 { margin: 0 0 0.5rem; font-size: 1.1em; line-height: 1.3; }
    .content-card p { margin: 0; font-size: 0.9em; color: #666; line-height: 1.4; }

    /* Downloads */
    .downloads-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
    .downloads-section h2 { margin: 0 0 0.3rem; font-size: 1.4em; }
    .downloads-sub { color: var(--color-muted); font-size: 0.9em; margin: 0 0 1.5rem; }
    .downloads-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .download-card {
      display: flex; gap: 0.75rem; align-items: start;
      border: 1px solid var(--color-border); border-radius: 8px; padding: 1rem;
      text-decoration: none; color: inherit; transition: all 0.15s;
    }
    .download-card:hover { border-color: var(--color-accent); box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .dl-icon { font-size: 1.3em; flex-shrink: 0; margin-top: 0.1em; }
    .download-card strong { display: block; font-size: 0.9em; margin-bottom: 0.15rem; }
    .download-card p { margin: 0; font-size: 0.78em; color: var(--color-muted); line-height: 1.4; }
    @media (max-width: 768px) {
      .downloads-grid { grid-template-columns: 1fr; }
      .content-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .pro-header h1 { font-size: 1.8em; }
      .pro-header { padding: 1rem 0; margin-bottom: 1.25rem; }
      .pro-header p { font-size: 0.9em; }
      .content-grid { grid-template-columns: 1fr; gap: 1rem; }
      .content-card { padding: 1rem; }
      .content-card h3 { font-size: 1em; }
      .content-card p { font-size: 0.85em; }
      .gate-card { padding: 1.5rem 1rem 1rem; }
      .gate-card h2 { font-size: 1.3em; }
      .gate-btn { display: block; width: 100%; text-align: center; padding: 0.85rem 1.5rem; min-height: 44px; }
      .download-card { padding: 0.85rem; }
      .download-card strong { font-size: 0.85em; }
      .download-card p { font-size: 0.75em; }
      .auth-gate { margin: 2rem auto; }
    }
    @media (max-width: 360px) {
      .pro-header h1 { font-size: 1.5em; }
      .content-card { padding: 0.85rem; }
      .gate-card { padding: 1.25rem 0.85rem 0.85rem; }
    }

    /* Auth gate */
    .auth-gate { max-width: 400px; margin: 4rem auto; text-align: center; }
    .gate-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem 2.5rem 1.5rem; }
    .gate-card h2 { margin: 0 0 0.5rem; font-size: 1.5em; }
    .gate-card > p { color: var(--color-muted); font-size: 0.92em; margin: 0 0 1.5rem; }
    .gate-btn {
      display: inline-block; background: var(--color-accent); color: white;
      padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;
      text-decoration: none; font-size: 0.95em;
    }
    .gate-btn:hover { opacity: 0.9; text-decoration: none; }
    .gate-sub { font-size: 0.82em; color: var(--color-muted); margin: 1.25rem 0 0; }
    .gate-sub a { color: var(--color-accent); }

    .tier-gated { opacity: 0.45; pointer-events: auto; position: relative; }
    .template-locked { opacity: 0.5; cursor: pointer; position: relative; }
    .template-locked::after {
      content: 'Inner Circle'; position: absolute; top: 0.6rem; right: 0.6rem;
      background: #f59e0b; color: white; font-size: 0.65em; font-weight: 700;
      padding: 0.15rem 0.5rem; border-radius: 4px; letter-spacing: 0.04em;
    }
    .tier-gated::after {
      content: 'Inner Circle'; position: absolute; top: 0.75rem; right: 0.75rem;
      background: #f59e0b; color: white; font-size: 0.65em; font-weight: 700;
      padding: 0.15rem 0.5rem; border-radius: 4px; letter-spacing: 0.04em;
    }
  </style>

  <script>
    const API = window.API_URL;
    const sid = localStorage.getItem('ae_session');

    async function checkAccess() {
      if (!sid) return false;
      try {
        const res = await fetch(`${API}/api/auth/session`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ session_id: sid })
        });
        const data = await res.json();
        if (data.success && (data.tier === 'pro' || data.tier === 'inner')) {
          // Sync localStorage with server tier
          localStorage.setItem('ae_tier', data.tier);
          return true;
        }
        return false;
      } catch { return false; }
    }

    if (sid) {
      checkAccess().then(ok => {
        if (ok) {
          document.getElementById('pro-content').style.display = 'block';

          const userTier = localStorage.getItem('ae_tier');

          if (userTier === 'inner') {
            // Inner Circle — full access, remove all locks
            document.querySelectorAll('.founding-locked').forEach(card => {
              card.classList.remove('tier-gated');
            });
          } else {
            // Pro — lock founding content and templates, redirect to upgrade
            document.querySelectorAll('.founding-locked').forEach(card => {
              card.classList.add('tier-gated');
              card.addEventListener('click', (e) => {
                e.preventDefault();
                window.location.href = '/upgrade?tier=inner';
              });
            });
            document.querySelectorAll('.download-card').forEach(card => {
              card.classList.add('template-locked');
              card.addEventListener('click', (e) => {
                e.preventDefault();
                window.location.href = '/upgrade?tier=inner';
              });
            });
          }
        } else {
          // Signed in but free tier — show upgrade gate
          document.getElementById('auth-gate-upgrade').style.display = 'block';
        }
      });
    } else {
      // Not signed in — show sign in gate
      document.getElementById('auth-gate-signin').style.display = 'block';
    }
  </script>
</BaseLayout>
