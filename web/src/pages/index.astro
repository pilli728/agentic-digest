---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allDigests = await getCollection('digests');
const now = new Date();
const parseLocal = (s: string) => { const [y,m,d] = s.split('-').map(Number); return new Date(y, m-1, d); };
const digests = allDigests.filter(d => parseLocal(d.data.date) <= now);
const sorted = digests.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latest = sorted[0];
const previous = sorted[1];
let latestContent;
if (latest) {
  latestContent = await latest.render();
}

// Get latest premium articles for locked cards (filter out future dates, except featured_free)
const allPremium = await getCollection('premium');
const publishedPremium = allPremium.filter(p => parseLocal(p.data.date) <= now || p.data.featured_free);
const premiumSorted = publishedPremium.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featuredFreeArticle = publishedPremium.find(p => p.data.featured_free === true);
const latestPro = premiumSorted.find(p => p.data.tier === 'pro' && !p.data.featured_free);
const latestFounding = premiumSorted.find(p => p.data.tier === 'founding');

// Opinion section keyword detection
const OPINION_KEYWORDS = ["pilli's take", "your move", "my take", "the take", "editor's note", "hot take"];

// Parse digest markdown into sections for the front page
function parseDigest(rawBody: string) {
  const sections: { title: string; tagline: string; isOpinion: boolean; prose: string; stories: { title: string; url: string; summary: string; source: string }[] }[] = [];
  const lines = rawBody.split('\n');
  let currentSection: typeof sections[0] | null = null;
  let currentStory: typeof sections[0]['stories'][0] | null = null;

  for (const line of lines) {
    // H2 = section header
    if (line.startsWith('## ')) {
      if (currentStory && currentSection) currentSection.stories.push(currentStory);
      currentStory = null;
      if (currentSection) sections.push(currentSection);
      const title = line.replace('## ', '');
      const isOpinion = OPINION_KEYWORDS.some(kw => title.toLowerCase().includes(kw));
      currentSection = { title, tagline: '', isOpinion, prose: '', stories: [] };
    }
    // Italic line after H2 = tagline
    else if (line.startsWith('*') && line.endsWith('*') && currentSection && !currentSection.tagline) {
      currentSection.tagline = line.replace(/^\*|\*$/g, '');
    }
    // H3 with link = story (only for non-opinion sections)
    else if (line.startsWith('### [') && currentSection && !currentSection.isOpinion) {
      if (currentStory && currentSection) currentSection.stories.push(currentStory);
      const titleMatch = line.match(/### \[([^\]]+)\]\(([^)]+)\)/);
      if (titleMatch) {
        currentStory = { title: titleMatch[1], url: titleMatch[2], summary: '', source: '' };
        // Extract source from URL
        try {
          const hostname = new URL(titleMatch[2]).hostname.replace('www.', '');
          const domainMap: Record<string, string> = {
            'fortune.com': 'Fortune', 'arcprize.org': 'ARC Prize', 'stripe.com': 'Stripe',
            'github.com': 'GitHub', 'remotion.dev': 'Remotion', 'x.com': 'X',
            'threads.com': 'Threads', 'thevccorner.com': 'The VC Corner',
          };
          currentStory.source = domainMap[hostname] || hostname.split('.')[0].charAt(0).toUpperCase() + hostname.split('.')[0].slice(1);
        } catch { currentStory.source = ''; }
      }
    }
    // Text after H3 = story summary
    else if (currentStory && line.trim() && !line.startsWith('#') && !line.startsWith('---') && !line.startsWith('*')) {
      currentStory.summary += (currentStory.summary ? ' ' : '') + line.trim();
    }
    // Prose for opinion sections
    else if (currentSection?.isOpinion && line.trim() && !line.startsWith('#') && !line.startsWith('---')) {
      currentSection.prose += (currentSection.prose ? '\n' : '') + line.trim();
    }
  }
  if (currentStory && currentSection) currentSection.stories.push(currentStory);
  if (currentSection) sections.push(currentSection);
  return sections;
}

let digestSections: ReturnType<typeof parseDigest> = [];
if (latest) {
  const rawBody = latest.body || '';
  digestSections = parseDigest(rawBody);
}

const formatDate = (dateStr) => {
  const [year, month, day] = dateStr.split('-').map(Number);
  const date = new Date(year, month - 1, day);
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
