<BaseLayout title="Agentic Edge" description="Pilli's weekly brief for AI builders. Stanford engineer, building AI agents since before ChatGPT. 700+ sources scanned. Only what matters.">
  <header class="home-header">
    <h1>Agentic Edge</h1>
    <p class="tagline">Your unfair advantage as an AI builder.</p>
    <p class="sub-tagline">700+ sources scanned. Only what matters. Every Monday.</p>
  </header>


  <!-- Company logos carousel -->
  <section class="logos-section">
    <p class="logos-label">Join builders and engineers from</p>
    <div class="logos-track">
      <div class="logos-slide">
        <span class="logo-item">Google</span>
        <span class="logo-item">Meta</span>
        <span class="logo-item">Anthropic</span>
        <span class="logo-item">OpenAI</span>
        <span class="logo-item">Apple</span>
        <span class="logo-item">Stanford</span>
        <span class="logo-item">NVIDIA</span>
        <span class="logo-item">Stripe</span>
        <span class="logo-item">Vercel</span>
        <span class="logo-item">Y Combinator</span>
        <span class="logo-item">a16z</span>
        <span class="logo-item">Amazon</span>
        <span class="logo-item">Microsoft</span>
        <span class="logo-item">Databricks</span>
        <!-- Duplicate for seamless loop -->
        <span class="logo-item">Google</span>
        <span class="logo-item">Meta</span>
        <span class="logo-item">Anthropic</span>
        <span class="logo-item">OpenAI</span>
        <span class="logo-item">Apple</span>
        <span class="logo-item">Stanford</span>
        <span class="logo-item">NVIDIA</span>
        <span class="logo-item">Stripe</span>
        <span class="logo-item">Vercel</span>
        <span class="logo-item">Y Combinator</span>
        <span class="logo-item">a16z</span>
        <span class="logo-item">Amazon</span>
        <span class="logo-item">Microsoft</span>
        <span class="logo-item">Databricks</span>
      </div>
    </div>
  </section>

  <!-- Email signup -->
  <section class="signup-section">
    <div class="signup-box">
      <h2>Join the builders who ship with AI</h2>
      <p class="signup-bio">I'm Pilli. Stanford engineer. I build AI agents for a living, and I still spent two hours a day just finding what mattered. So I automated it. Every week: the signal, and what top engineers are doing to stay ahead.</p>
      <form class="signup-form" id="signup-form">
        <input type="email" placeholder="you@company.com" required id="signup-email" />
        <button type="submit" class="btn btn-primary" id="signup-btn">Join for free</button>
      </form>
      <p class="signup-note">5-minute read. Every Monday. No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- Welcome modal overlay -->
  <div class="modal-overlay" id="welcome-modal">
    <div class="modal-card modal-welcome">
      <button class="modal-x" id="modal-x">×</button>

      <!-- Hand-drawn sketch at top -->
      <div class="modal-sketch modal-animate" style="animation-delay: 0.05s">
        <svg viewBox="0 0 240 120" class="modal-sketch-svg">
          <circle cx="80" cy="50" r="20" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="80" cy="45" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M70,55 L90,55" fill="none" stroke="currentColor" stroke-width="1"/>
          <circle cx="130" cy="50" r="20" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="130" cy="45" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M120,55 L140,55" fill="none" stroke="currentColor" stroke-width="1"/>
          <circle cx="180" cy="50" r="20" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="180" cy="45" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M170,55 L190,55" fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M100,50 L110,50" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2,2" opacity="0.4"/>
          <path d="M150,50 L160,50" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2,2" opacity="0.4"/>
          <path d="M60,80 L200,80" fill="none" stroke="currentColor" stroke-width="1" opacity="0.15"/>
          <path d="M55,85 L205,85" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.1"/>
        </svg>
      </div>

      <div class="modal-welcome-body modal-animate" style="animation-delay: 0.15s">
        <h2 class="modal-welcome-heading">Welcome to the frontier.</h2>
        <p class="modal-welcome-sub">You have joined a community of world-class builders who are expanding what is possible.</p>
        <p class="modal-email-line" id="modal-email"></p>
      </div>

      <div class="modal-welcome-divider"></div>

      <div class="modal-pro-box modal-animate" style="animation-delay: 0.3s">
        <div class="modal-pro-header">
          <span class="modal-pro-badge">Pro — $12/mo</span>
          <span class="modal-pro-sub">Most builders upgrade within a week</span>
        </div>
        <ul class="modal-pro-list">
          <li>15+ ranked sources with one-liners</li>
          <li>What I cut and why (editorial notes)</li>
        </ul>
        <a href="/upgrade" class="modal-pro-btn">Upgrade to Pro →</a>
      </div>

      <p class="modal-inbox-note modal-animate" style="animation-delay: 0.4s">Check your inbox — we sent a magic link to sign in.</p>
      <button class="modal-close-btn modal-animate" style="animation-delay: 0.45s" id="modal-close">Got it</button>
    </div>
  </div>

  <!-- Two-column digest layout -->
  {latest ? (
    <section class="digest-layout">
      <!-- Main content column -->
      <div class="digest-main">
        <div class="digest-header-row">
          <h2 class="digest-title">This Week's Digest</h2>
          <p class="digest-date-label">{formatDate(latest.data.date)}</p>
        </div>

        <!-- Locked top story — FREE users see Pro article, PRO users see Founding article -->
        <!-- Version for free users: latest Pro article (hidden when featured free exists) -->
        {latestPro && !featuredFreeArticle && (
        <a href="/upgrade" class="locked-card" id="locked-top-free">
          <div class="locked-badge">PRO</div>
          <div class="locked-content">
            <h3>{latestPro.data.title}</h3>
            <p>{latestPro.data.description}</p>
          </div>
          <div class="locked-blur"></div>
          <span class="locked-cta">Unlock with Pro →</span>
        </a>
        )}
        {featuredFreeArticle && (
        <a href={`/pro/${featuredFreeArticle.slug}`} class="featured-free-card featured-free-top" id="locked-top-free-article">
          <div class="featured-free-meta">
            <span class="featured-free-badge">Free Pro Article</span>
          </div>
          <h3>{featuredFreeArticle.data.title}</h3>
          <p>{featuredFreeArticle.data.description}</p>
          <span class="featured-free-cta">Read the full article — free, no login →</span>
        </a>
        )}
        <!-- Version for Pro users: latest Founding article -->
        {latestFounding && (
        <a href="/upgrade?tier=inner" class="locked-card locked-card-gold" id="locked-top-pro" style="display:none">
          <div class="locked-badge" style="background:#f59e0b">INNER CIRCLE</div>
          <div class="locked-content">
            <h3>{latestFounding.data.title}</h3>
            <p>{latestFounding.data.description}</p>
          </div>
          <div class="locked-blur"></div>
          <span class="locked-cta">Unlock with Inner Circle →</span>
        </a>
        )}
        <!-- Version for Inner Circle: latest Founding article unlocked -->
        {latestFounding && (
        <a href={`/pro/${latestFounding.slug}`} class="locked-card locked-card-gold" id="locked-top-inner" style="display:none">
          <div class="locked-badge" style="background:#f59e0b">INNER CIRCLE</div>
          <div class="locked-content">
            <h3>{latestFounding.data.title}</h3>
            <p>{latestFounding.data.description}</p>
          </div>
          <span class="locked-cta" style="background:rgba(245,158,11,0.15); color:#b45309;">Read now →</span>
        </a>
        )}

        <!-- Sketch divider -->
        <div class="sketch-divider">
          <svg viewBox="0 0 400 30" class="sketch-svg">
            <path d="M0,15 Q20,5 40,15 T80,15 T120,15 T160,15 T200,15 T240,15 T280,15 T320,15 T360,15 T400,15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.15"/>
          </svg>
        </div>

        <!-- All cards — dynamically rendered from latest digest -->
        <div class="source-cards">
          {digestSections.map((section, si) => (
            <>
              <div class="source-cards-header" style={si > 0 ? "margin-top: 1.75rem;" : ""}>
                <h3 class="source-cards-label">{section.title}</h3>
                <p class="source-cards-sub">{section.tagline}</p>
              </div>
              {section.isOpinion ? (
                <div class="opinion-prose">
                  {section.prose.split('\n').filter(p => p.trim()).map(para => (
                    <p>{para}</p>
                  ))}
                </div>
              ) : (
                section.stories.map(story => (
                  <div class="source-card">
                    <div class="source-card-text">
                      <strong>{story.title}</strong>
                      <p>{story.summary.length > 200 ? story.summary.substring(0, 200) + '...' : story.summary}</p>
                      <div class="source-card-footer">
                        <span class="source-meta">{story.source}</span>
                        {story.url && <a href={story.url} class="read-original" target="_blank" rel="noopener noreferrer">Read original →</a>}
                      </div>
                    </div>
                  </div>
                ))
              )}
            </>
          ))}

        </div>

        {previous && (
          <a href={`/archive/${previous.slug}`} class="prev-digest-card">
            <span class="prev-digest-date">{formatDate(previous.data.date)}</span>
            <strong>{previous.data.title.replace('Agentic Edge Digest - ', 'Week of ')}</strong>
            <p>Read the previous issue.</p>
            <span class="prev-digest-link">Read last week's digest →</span>
          </a>
        )}
      </div>

      <!-- Right sidebar -->
      <aside class="digest-sidebar">
        <div class="sidebar-sticky">
          <!-- Sketch illustration: tools -->
          <div class="sketch-illustration">
            <svg viewBox="0 0 200 120" class="sketch-svg sidebar-sketch">
              <path d="M60,90 L60,40 Q60,30 70,30 L130,30 Q140,30 140,40 L140,90" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <path d="M50,90 L150,90" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <circle cx="100" cy="60" r="15" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <path d="M100,45 L100,35" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <path d="M85,60 L75,60" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <path d="M115,60 L125,60" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
            </svg>
          </div>

          <div class="sidebar-section" id="sidebar-pro-cards">
            <h4 class="sidebar-label" id="sidebar-cards-label">Premium Content</h4>

            <!-- Pro-tier articles — link to article (teaser handles gating) -->
            <a href="/pro/07-vibecoding-masterclass" class="sidebar-card tier-pro-card">
              <strong>The Vibecoding Masterclass</strong>
              <p>8 hacks that separate 10x AI coders from everyone else.</p>
            </a>

            <a href="/pro/03-writing-voice-guide" class="sidebar-card tier-pro-card">
              <strong>Anti-AI Writing Guide</strong>
              <p>25 banned phrases and the formula for human copy.</p>
            </a>

            <!-- Founding-tier articles -->
            <a href="/pro/10-budget-llm-spreadsheet" class="sidebar-card tier-founding-card">
              <strong>The Budget LLM Spreadsheet</strong>
              <p>One model switch. 87% cost reduction. Same output.</p>
            </a>

            <a href="/pro/11-agents-md-masterclass" class="sidebar-card tier-founding-card">
              <strong>AGENTS.md Masterclass</strong>
              <p>Why the "tech stack mini-map" approach fails.</p>
            </a>

            <a href="/pro/12-claude-code-cheat-sheet" class="sidebar-card tier-founding-card">
              <strong>Claude Code Cheat Sheet</strong>
              <p>Keybindings, hooks, and syntax not in the docs.</p>
            </a>

            <a href="/pro/13-openclaw-week-one-setup" class="sidebar-card tier-founding-card">
              <strong>OpenClaw Week-One Setup</strong>
              <p>Lock your gateway before you connect anything.</p>
            </a>

            <a href="/pro/14-auto-mode-breakdown" class="sidebar-card tier-founding-card">
              <strong>Auto Mode Breakdown</strong>
              <p>How memory consolidation works and what gets pruned.</p>
            </a>
          </div>

          <!-- Sketch illustration: graph -->
          <div class="sketch-illustration">
            <svg viewBox="0 0 200 80" class="sketch-svg sidebar-sketch">
              <path d="M20,60 Q40,55 60,50 T100,30 T140,25 T180,15" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.12"/>
              <path d="M20,65 L180,65" fill="none" stroke="currentColor" stroke-width="1" opacity="0.08"/>
              <circle cx="100" cy="30" r="3" fill="currentColor" opacity="0.1"/>
              <circle cx="140" cy="25" r="3" fill="currentColor" opacity="0.1"/>
              <circle cx="180" cy="15" r="3" fill="currentColor" opacity="0.1"/>
            </svg>
          </div>

          <a href="/upgrade" class="sidebar-upgrade" id="sidebar-upgrade">
            <strong>Unlock Pro</strong>
            <span>$12/month</span>
            <p>Full source list, editorial notes, early access Friday.</p>
          </a>
          <a href="/upgrade?tier=inner" class="sidebar-upgrade sidebar-upgrade-gold" id="sidebar-upgrade-gold" style="display:none">
            <strong>Unlock Inner Circle</strong>
            <span>$39/month</span>
            <p>Tool drops, templates, agents, DM access.</p>
          </a>

          <!-- Sketch illustration: paper airplane -->
          <div class="sketch-illustration">
            <svg viewBox="0 0 200 100" class="sketch-svg sidebar-sketch">
              <path d="M30,70 L170,30 L120,55 L130,80 L105,58 Z" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.1"/>
              <path d="M30,70 L120,55" fill="none" stroke="currentColor" stroke-width="1" opacity="0.08"/>
            </svg>
          </div>
        </div>
      </aside>
    </section>
  ) : (
    <div class="no-content">
      <p>First issue coming soon. Subscribe above to be the first to know.</p>
    </div>
  )}

  <!-- About — minimal -->
  <section class="about" id="about-section">
    <div class="about-text">
      <p>Made by <strong>Pilli</strong> — Stanford engineer, 2 years building AI agents, in AI since before ChatGPT. This is the briefing I wish existed when I started.</p>
    </div>
  </section>

  <!-- Subscribed state (hidden by default, replaces about) -->
  <section class="subscribed-section" id="subscribed-section" style="display:none">
    <div class="subscribed-text">
      <p>Welcome to the frontier. You have joined a community of world-class builders who are expanding what is possible.</p>
    </div>
  </section>

  <footer class="site-footer">
    <p>Made by Pilli. <a href="/archive">Archive</a> · <a href="/pro">The Vault</a> · <a href="/upgrade">Upgrade</a></p>
  </footer>

  <style>
    /* Header */
    .home-header { text-align: center; padding: 3rem 0 1.5rem; margin-bottom: 1.5rem; }
    h1 { font-size: 3em; margin: 0 0 0.5rem; letter-spacing: -0.02em; }
    .tagline { font-size: 1.15em; color: var(--color-muted); margin: 0 0 0.3rem; }
    .sub-tagline { font-size: 0.85em; color: var(--color-muted); opacity: 0.7; margin: 0; }

    /* Personal intro */
    .personal-intro { max-width: 560px; margin: 0 auto 1.75rem; text-align: center; }
    .personal-intro p { font-size: 0.9em; color: var(--color-muted); line-height: 1.6; margin: 0; }
    .personal-intro strong { color: var(--color-fg); }
    .briefing-desc { margin-top: 0.75rem !important; font-size: 0.85em !important; color: #999 !important; }

    /* Logo carousel */
    .logos-section { text-align: center; margin-bottom: 2rem; overflow: hidden; }
    .logos-label { font-size: 0.72em; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 0.75rem; }
    .logos-track { overflow: hidden; mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); }
    .logos-slide { display: flex; gap: 3rem; animation: scroll 25s linear infinite; width: max-content; }
    .logo-item { font-size: 1em; font-weight: 600; color: var(--color-border); white-space: nowrap; letter-spacing: 0.02em; flex-shrink: 0; }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .logos-track:hover .logos-slide { animation-play-state: paused; }

    /* Signup */
    .signup-section { margin-bottom: 2.5rem; }
    .signup-box { background: var(--color-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.75rem; text-align: center; }
    .signup-box h2 { margin: 0 0 0.4rem; font-size: 1.2em; }
    .signup-box > p { color: var(--color-muted); margin: 0 0 1.25rem; font-size: 0.9em; line-height: 1.55; }
    .signup-form { display: flex; gap: 0.5rem; justify-content: center; max-width: 440px; margin: 0 auto 0.75rem; }
    .signup-form input { flex: 1; padding: 0.7rem 0.9rem; border: 1px solid var(--color-border); border-radius: 6px; font-size: 0.9em; background: var(--color-bg); color: var(--color-fg); }
    .signup-form input:focus { outline: none; border-color: var(--color-accent); }
    .signup-note { font-size: 0.75em; color: var(--color-muted); margin: 0; }
    .signup-bio { font-size: 0.88em; color: var(--color-muted); line-height: 1.6; margin: 0 0 1.25rem; }
    .btn-primary {
      padding: 0.7rem 1.4rem;
      background: #7c3aed;
      color: white;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-primary:hover { background: #6d28d9; }

    /* Featured free pro article */
    .featured-free-section { margin-bottom: 2rem; }
    .featured-free-label {
      font-size: 0.7em; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--color-accent); font-weight: 600; margin-bottom: 0.6rem;
    }
    .featured-free-card {
      display: block; background: var(--color-card); border: 1px solid var(--color-accent);
      border-radius: 10px; padding: 1.25rem 1.5rem; text-decoration: none; color: inherit;
      transition: box-shadow 0.2s; opacity: 0.95;
    }
    .featured-free-card:hover { box-shadow: 0 4px 16px rgba(124,58,237,0.1); text-decoration: none; opacity: 1; }
    .featured-free-meta { margin-bottom: 0.5rem; display: flex; gap: 0.5rem; align-items: center; }
    .featured-free-badge {
      font-size: 0.65em; text-transform: uppercase; letter-spacing: 0.1em;
      background: rgba(124,58,237,0.12); color: var(--color-accent);
      padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: 700;
    }
    .featured-free-category {
      font-size: 0.7em; text-transform: uppercase; letter-spacing: 0.08em;
      background: rgba(124,58,237,0.08); color: var(--color-accent);
      padding: 0.15rem 0.5rem; border-radius: 3px; font-weight: 600;
    }
    .featured-free-card h3 { margin: 0 0 0.35rem; font-size: 1.05em; line-height: 1.35; color: var(--color-fg); }
    .featured-free-card p { margin: 0 0 0.75rem; font-size: 0.85em; color: var(--color-muted); line-height: 1.5; }
    .featured-free-cta { font-size: 0.82em; font-weight: 600; color: var(--color-accent); }

    /* ===== Two-column digest layout ===== */
    .digest-layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 2.5rem;
      align-items: start;
      margin-bottom: 2rem;
    }

    .digest-header-row {
      display: flex; justify-content: space-between; align-items: baseline;
      border-bottom: 1px solid var(--color-border); padding-bottom: 0.75rem; margin-bottom: 1.25rem;
    }
    .digest-title { margin: 0; font-size: 1.4em; }
    .digest-date-label { font-size: 0.82em; color: var(--color-muted); margin: 0; }

    /* Locked top story */
    .locked-card {
      display: block; position: relative; background: var(--color-card);
      border: 2px solid var(--color-accent); border-radius: 10px;
      padding: 1.5rem 1.5rem 1.25rem; margin-bottom: 1.5rem;
      text-decoration: none; color: inherit; transition: box-shadow 0.2s;
    }
    .locked-card:hover { box-shadow: 0 4px 16px rgba(124,58,237,0.12); text-decoration: none; }
    .locked-card-gold { border-color: #f59e0b; }
    .locked-card-gold:hover { box-shadow: 0 4px 16px rgba(245,158,11,0.15); }
    .locked-badge {
      display: inline-block; background: var(--color-accent); color: white;
      padding: 0.15rem 0.6rem; border-radius: 4px;
      font-size: 0.68em; font-weight: 700; letter-spacing: 0.06em;
      margin-bottom: 0.6rem;
    }
    .locked-content h3 { margin: 0 0 0.4rem; font-size: 1.05em; line-height: 1.35; }
    .locked-content p { margin: 0; font-size: 0.85em; color: var(--color-muted); line-height: 1.5; }
    .locked-blur { display: none; }
    .locked-cta {
      display: inline-block; margin-top: 0.75rem;
      font-size: 0.82em; font-weight: 600; color: var(--color-accent);
    }

    /* Sketch dividers & illustrations */
    .sketch-divider { text-align: center; margin: 0.5rem 0; }
    .sketch-svg { width: 100%; max-width: 300px; height: auto; color: var(--color-fg); }
    .sketch-illustration { text-align: center; margin: 1.25rem 0; }
    .sidebar-sketch { width: 120px; height: auto; color: var(--color-fg); }

    /* Digest main content */
    .digest-scroll { line-height: 1.75; }
    .digest-scroll h2 { font-size: 1.25em; margin: 2rem 0 0.5rem; }
    .digest-scroll h3 { font-size: 1.05em; margin: 1.25rem 0 0.25rem; }
    .digest-scroll h3 a { color: var(--color-accent); }
    .digest-scroll p { font-size: 0.92em; color: #555; margin-bottom: 0.6rem; }
    .digest-scroll em { color: var(--color-muted); }
    .digest-scroll hr { border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0; }
    .digest-scroll blockquote {
      border-left: 3px solid var(--color-accent); margin: 1rem 0; padding: 0.5rem 1rem;
      font-style: italic; color: var(--color-muted); background: rgba(124,58,237,0.03); border-radius: 0 6px 6px 0;
    }
    .digest-scroll details {
      background: var(--color-card); border: 1px solid var(--color-border);
      border-radius: 8px; margin: 0.75rem 0; overflow: hidden;
    }
    .digest-scroll details:hover { border-color: #d0cec8; }
    .digest-scroll summary {
      padding: 1rem 1.25rem; cursor: pointer; list-style: none;
      font-size: 0.92em; line-height: 1.5; color: var(--color-fg); user-select: none;
    }
    .digest-scroll summary::-webkit-details-marker { display: none; }
    .digest-scroll summary::before { content: '+ '; color: var(--color-muted); font-weight: 400; }
    .digest-scroll details[open] summary::before { content: '- '; color: var(--color-accent); }
    .digest-scroll details > p,
    .digest-scroll details > blockquote { padding: 0 1.25rem; margin-bottom: 0.75rem; }
    .digest-scroll details > p:last-child { padding-bottom: 1.25rem; }

    /* ===== Right sidebar ===== */
    .digest-sidebar { font-size: 0.9em; }
    .sidebar-sticky { position: sticky; top: 2rem; }
    .sidebar-label {
      font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--color-muted); margin: 0 0 0.75rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border); font-family: 'Inter', sans-serif; font-weight: 600;
    }

    .sidebar-card {
      display: block; padding: 0.85rem 0; border-bottom: 1px solid var(--color-border);
      text-decoration: none; color: inherit; transition: opacity 0.15s;
    }
    .sidebar-card:hover { opacity: 0.75; text-decoration: none; }
    .sidebar-card strong { display: block; font-size: 0.88em; margin-bottom: 0.15rem; color: var(--color-fg); }
    .sidebar-card p { margin: 0; font-size: 0.8em; color: var(--color-muted); line-height: 1.45; }

    .sidebar-upgrade {
      display: block; background: var(--color-accent); color: white;
      padding: 1rem 1.1rem; border-radius: 8px; text-decoration: none;
      margin-top: 1.25rem; transition: opacity 0.15s;
    }
    .sidebar-upgrade:hover { opacity: 0.92; text-decoration: none; }
    .sidebar-upgrade strong { display: block; font-size: 0.95em; margin-bottom: 0.1rem; }
    .sidebar-upgrade span { font-size: 0.82em; opacity: 0.85; }
    .sidebar-upgrade p { margin: 0.4rem 0 0; font-size: 0.78em; opacity: 0.75; line-height: 1.4; }
    .sidebar-upgrade-gold { background: #f59e0b; }

    /* Source cards — Leverage style */
    .source-cards { margin-top: 2rem; }
    .source-cards-header {
      padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); margin-bottom: 0.75rem;
    }
    .source-cards-label {
      font-size: 1.05em; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--color-fg); margin: 0 0 0.15rem; font-family: 'Inter', sans-serif; font-weight: 700;
    }
    .source-cards-sub {
      font-size: 0.82em; color: var(--color-muted); margin: 0; font-style: italic;
    }
    /* Opinion prose sections */
    .opinion-prose { padding: 0.75rem 0 0.25rem; }
    .opinion-prose p { font-size: 0.92em; color: var(--color-fg); line-height: 1.65; margin-bottom: 0.75rem; }
    .opinion-prose p:last-child { margin-bottom: 0; }

    /* Source card footer with read-original link */
    .source-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 0.3rem; }
    .read-original { font-size: 0.72em; color: var(--color-accent); font-weight: 500; text-decoration: none; white-space: nowrap; }
    .read-original:hover { text-decoration: underline; }

    .source-card {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1.1rem 0; border-bottom: 1px solid var(--color-border);
      color: inherit;
    }
    .source-card:first-child { border-top: 1px solid var(--color-border); }
    .source-card-text { flex: 1; min-width: 0; }
    .source-card-text strong {
      display: block; font-size: 1em; font-family: 'Merriweather', serif;
      margin-bottom: 0.2rem; color: var(--color-fg); line-height: 1.35;
    }
    .source-card-text p {
      margin: 0; font-size: 0.85em; color: var(--color-muted); line-height: 1.45;
    }
    .source-meta {
      font-size: 0.72em; color: var(--color-muted); opacity: 0.7;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .source-card-sketch {
      width: 80px; height: 80px; flex-shrink: 0; color: var(--color-fg); opacity: 0.2;
    }

    /* Previous digest card */
    .prev-digest-card {
      display: block; margin-top: 1.5rem; padding: 1.25rem;
      background: var(--color-card); border: 1px solid var(--color-border);
      border-radius: 8px; text-decoration: none; color: inherit;
      opacity: 0.6; transition: opacity 0.15s;
    }
    .prev-digest-card:hover { opacity: 0.85; text-decoration: none; }
    .prev-digest-date {
      display: block; font-size: 0.7em; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--color-muted); margin-bottom: 0.3rem;
    }
    .prev-digest-card strong { display: block; font-size: 0.95em; margin-bottom: 0.25rem; }
    .prev-digest-card p { margin: 0; font-size: 0.82em; color: var(--color-muted); line-height: 1.45; }
    .prev-digest-link {
      display: block; margin-top: 0.5rem; font-size: 0.8em;
      color: var(--color-accent); font-weight: 600;
    }

    @media (max-width: 768px) {
      .source-card-sketch { width: 60px; height: 60px; }
    }

    /* About — minimal */
    .about { padding: 2rem 0; border-top: 1px solid var(--color-border); margin-top: 1rem; }
    .about-text { max-width: 580px; margin: 0 auto; text-align: center; }
    .about-text p { font-size: 0.9em; color: var(--color-muted); line-height: 1.6; margin: 0; }

    .subscribed-section { padding: 2rem 0; border-top: 1px solid var(--color-border); margin-top: 1rem; }
    .subscribed-text { max-width: 580px; margin: 0 auto; text-align: center; }
    .subscribed-text p { font-size: 0.95em; color: var(--color-fg); line-height: 1.6; margin: 0; font-weight: 500; }

    .site-footer { text-align: center; padding: 2rem 0; font-size: 0.82em; color: var(--color-muted); }
    .no-content { text-align: center; padding: 3rem; color: var(--color-muted); }

    /* === Welcome Modal === */
    .modal-overlay {
      display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
      z-index: 9999; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-overlay.active { display: flex; }
    .modal-card {
      background: var(--color-card); border-radius: 14px; padding: 2.25rem 2rem 1.75rem;
      max-width: 480px; width: 100%; position: relative;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes modalSlideUp { from { transform: translateY(48px) scale(0.97); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    .modal-animate { opacity: 0; animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .modal-x { position: absolute; top: 1.1rem; right: 1.25rem; background: none; border: none; color: #bbb; font-size: 1.4em; cursor: pointer; line-height: 1; padding: 0; z-index: 1; }
    .modal-x:hover { color: #333; }

    .modal-welcome { padding: 1.5rem 2rem 1.75rem; max-width: 440px; }

    .modal-sketch { text-align: center; margin-bottom: 0.5rem; }
    .modal-sketch-svg { width: 180px; height: auto; color: var(--color-fg); opacity: 0.15; }

    .modal-welcome-body { text-align: center; margin-bottom: 1.25rem; }
    .modal-welcome-heading {
      font-size: 1.6em; margin: 0 0 0.5rem; color: var(--color-fg);
      font-family: 'Merriweather', serif; line-height: 1.25;
    }
    .modal-welcome-sub {
      font-size: 0.95em; color: var(--color-muted); line-height: 1.55; margin: 0 0 0.75rem;
    }
    .modal-email-line { font-size: 0.82em; color: var(--color-accent); font-weight: 500; margin: 0; }

    .modal-welcome-divider { height: 1px; background: var(--color-border); margin: 0 0 1.25rem; }
    .modal-pro-box { background: rgba(124,58,237,0.04); border: 1.5px solid var(--color-accent); border-radius: 10px; padding: 1.1rem 1.25rem; margin-bottom: 1rem; }
    .modal-pro-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .modal-pro-badge { background: var(--color-accent); color: white; padding: 0.2rem 0.7rem; border-radius: 20px; font-size: 0.75em; font-weight: 600; }
    .modal-pro-sub { font-size: 0.78em; color: var(--color-muted); }
    .modal-pro-list { list-style: none; padding: 0; margin: 0 0 0.85rem; }
    .modal-pro-list li { font-size: 0.83em; color: #444; padding: 0.2rem 0; }
    .modal-pro-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 600; }
    .modal-pro-btn { display: block; width: 100%; text-align: center; background: var(--color-accent); color: white; padding: 0.7rem; border-radius: 7px; font-size: 0.88em; font-weight: 600; text-decoration: none; min-height: 44px; display: flex; align-items: center; justify-content: center; }
    .modal-pro-btn:hover { background: var(--color-accent-hover); text-decoration: none; }
    .modal-inbox-note { text-align: center; font-size: 0.82em; color: var(--color-muted); margin: 0 0 0.5rem; }
    .modal-close-btn { display: block; width: 100%; padding: 0.65rem; background: transparent; color: var(--color-muted); border: 1px solid var(--color-border); border-radius: 7px; font-size: 0.84em; cursor: pointer; font-family: 'Inter', sans-serif; min-height: 44px; }
    .modal-close-btn:hover { color: var(--color-fg); border-color: #ccc; }

    /* Responsive */
    @media (max-width: 768px) {
      .digest-layout { grid-template-columns: 1fr; }
      .digest-sidebar { order: 1; }
      .sidebar-sticky { position: static; }
      .sketch-illustration { display: none; }
      .signup-form { flex-direction: column; }
      .signup-form input { text-align: left; min-height: 44px; }
      .btn-primary { width: 100%; padding: 0.75rem 1rem; min-height: 44px; }
      h1 { font-size: 2.2em; }
      .home-header { padding: 2rem 0 1rem; }
      .source-card-sketch { width: 50px; height: 50px; }
      .logos-slide { gap: 1.5rem; }
      .modal-card { padding: 1.25rem 1rem 1rem; }
      .locked-card { padding: 1.25rem; }
    }
    @media (max-width: 480px) {
      h1 { font-size: 1.8em; }
      .home-header { padding: 1.5rem 0 0.75rem; margin-bottom: 1rem; }
      .tagline { font-size: 1em; }
      .signup-box { padding: 1.25rem 1rem; }
      .signup-box h2 { font-size: 1.05em; }
      .signup-box > p { font-size: 0.85em; }
      .source-card-sketch { width: 40px; height: 40px; }
      .logos-slide { gap: 1rem; }
      .locked-card { padding: 1rem; margin-bottom: 1rem; }
      .locked-content h3 { font-size: 0.95em; }
      .source-card-text strong { font-size: 0.92em; }
      .source-card-text p { font-size: 0.82em; }
      .modal-card { padding: 1rem 0.85rem 0.85rem; max-width: 95vw; }
      .modal-welcome { padding: 1.25rem 1rem 1.25rem; }
      .modal-welcome-heading { font-size: 1.1em; }
      .modal-pro-box { padding: 0.85rem 1rem; }
      .modal-pro-header { flex-direction: column; gap: 0.3rem; }
      .prev-digest-card { padding: 1rem; }
      .about-text p { font-size: 0.85em; }
    }
    @media (max-width: 360px) {
      h1 { font-size: 1.5em; }
      .signup-box { padding: 1rem 0.75rem; }
      .signup-form input { padding: 0.65rem 0.75rem; font-size: 0.85em; }
      .btn-primary { font-size: 0.85em; }
      .source-cards-label { font-size: 0.95em; }
    }
  </style>

  <script>
    // Handle Stripe checkout success redirect
    (async function() {
      var params = new URLSearchParams(window.location.search);
      if (params.get('upgraded') === 'true' && params.get('session_id')) {
        try {
          var res = await fetch(window.API_URL + '/api/checkout/verify', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ session_id: params.get('session_id') })
          });
          var data = await res.json();
          if (data.success) {
            // Track upgrade event
            if (window.plausible) window.plausible('Upgrade', {props: {tier: data.tier}});
            // Update localStorage with new tier
            localStorage.setItem('ae_tier', data.tier);
            if (data.email) localStorage.setItem('ae_email', data.email);
            // Clean URL and reload to reflect new tier
            window.history.replaceState({}, '', '/');
            window.location.reload();
            return;
          }
        } catch (e) {
          console.error('Checkout verify failed:', e);
        }
      }
    })();

    // Tier-based content gating
    (function() {
      var tier = localStorage.getItem('ae_tier');
      var label = document.getElementById('sidebar-cards-label');
      var upgradeCard = document.getElementById('sidebar-upgrade');
      var goldCard = document.getElementById('sidebar-upgrade-gold');
      var topCard = document.getElementById('locked-top-card');

      var topFree = document.getElementById('locked-top-free');
      var topPro = document.getElementById('locked-top-pro');
      var topInner = document.getElementById('locked-top-inner');

      if (tier === 'free' || !tier) {
        // FREE: Show Pro article as locked, mix of pro+founding sidebar cards
        // All defaults from HTML are correct
      }

      else if (tier === 'pro') {
        if (topFree) topFree.style.display = 'none';
        var freeArticle = document.getElementById('locked-top-free-article');
        if (freeArticle) freeArticle.style.display = 'none';
        if (topPro) topPro.style.display = 'block';
        if (label) label.textContent = 'Inner Circle Only';
        document.querySelectorAll('.tier-pro-card').forEach(function(c) { c.style.display = 'none'; });
        if (upgradeCard) upgradeCard.style.display = 'none';
        if (goldCard) goldCard.style.display = 'block';
      }

      else if (tier === 'inner') {
        if (topFree) topFree.style.display = 'none';
        var freeArticle2 = document.getElementById('locked-top-free-article');
        if (freeArticle2) freeArticle2.style.display = 'none';
        if (topInner) topInner.style.display = 'block';
        if (label) label.textContent = 'Your Inner Circle Content';
        document.querySelectorAll('.tier-pro-card').forEach(function(c) { c.style.display = 'none'; });
        document.querySelectorAll('.tier-founding-card').forEach(function(c) {
          var url = c.dataset.article;
          if (url) c.href = url;
        });
        if (upgradeCard) upgradeCard.style.display = 'none';
        if (goldCard) goldCard.style.display = 'none';
      }
    })();

    // Signup form
    document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('signup-email');
      const email = emailInput.value;
      const btn = document.getElementById('signup-btn');

      btn.textContent = 'Joining...';
      btn.disabled = true;

      let data;
      try {
        const res = await fetch(window.API_URL + '/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        data = await res.json();

        // Dev mode: follow the link directly
        if (data.dev_link) {
          window.location.href = data.dev_link;
          return;
        }

        if (!data.success) {
          btn.textContent = 'Something went wrong. Try again.';
          btn.style.background = '#ef4444';
          btn.disabled = false;
          setTimeout(() => { btn.textContent = 'Join for free'; btn.style.background = ''; }, 3000);
          return;
        }
      } catch (err) {
        btn.textContent = 'Connection error. Try again.';
        btn.style.background = '#ef4444';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = 'Join for free'; btn.style.background = ''; }, 3000);
        return;
      }

      // Show welcome modal
      document.getElementById('modal-email').textContent = email;
      document.getElementById('welcome-modal').classList.add('active');
      if (window.plausible) window.plausible('Signup', {props: {email: email}});

      // Update signup box
      emailInput.style.display = 'none';
      btn.textContent = "Check your inbox";
      btn.style.background = '#7c3aed';
      btn.style.color = 'white';
      btn.disabled = true;
      btn.style.opacity = '1';
      btn.style.cursor = 'default';

      const aboutEl = document.getElementById('about-section');
      const subscribedEl = document.getElementById('subscribed-section');
      if (aboutEl) aboutEl.style.display = 'none';
      if (subscribedEl) subscribedEl.style.display = 'block';
    });

    // Close modal handlers
    function closeModal() {
      document.getElementById('welcome-modal').classList.remove('active');
    }
    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-x')?.addEventListener('click', closeModal);
    document.getElementById('welcome-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeModal();
    });
  </script>
</BaseLayout>
