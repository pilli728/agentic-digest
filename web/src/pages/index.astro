        <span class="logo-item">Stanford</span>
        <span class="logo-item">NVIDIA</span>
        <span class="logo-item">Stripe</span>
        <span class="logo-item">Vercel</span>
        <span class="logo-item">Y Combinator</span>
        <span class="logo-item">a16z</span>
        <span class="logo-item">Amazon</span>
        <span class="logo-item">Microsoft</span>
        <span class="logo-item">Databricks</span>
        <!-- Duplicate for seamless loop -->
        <span class="logo-item">Google</span>
        <span class="logo-item">Meta</span>
        <span class="logo-item">Anthropic</span>
        <span class="logo-item">OpenAI</span>
        <span class="logo-item">Apple</span>
        <span class="logo-item">Stanford</span>
        <span class="logo-item">NVIDIA</span>
        <span class="logo-item">Stripe</span>
        <span class="logo-item">Vercel</span>
        <span class="logo-item">Y Combinator</span>
        <span class="logo-item">a16z</span>
        <span class="logo-item">Amazon</span>
        <span class="logo-item">Microsoft</span>
        <span class="logo-item">Databricks</span>
