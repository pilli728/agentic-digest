    .logos-track:hover .logos-slide { animation-play-state: paused; }

    /* Signup */
    .signup-section { margin-bottom: 2.5rem; }
    .signup-box { background: var(--color-card); border: 1px solid var(--color-border); border-radius: 10px; padding: 1.75rem; text-align: center; }
    .signup-box h2 { margin: 0 0 0.4rem; font-size: 1.2em; }
    .signup-box > p { color: var(--color-muted); margin: 0 0 1.25rem; font-size: 0.9em; line-height: 1.55; }
    .signup-form { display: flex; gap: 0.5rem; justify-content: center; max-width: 440px; margin: 0 auto 0.75rem; }
    .signup-form input { flex: 1; padding: 0.7rem 0.9rem; border: 1px solid var(--color-border); border-radius: 6px; font-size: 0.9em; background: var(--color-bg); color: var(--color-fg); }
    .signup-form input:focus { outline: none; border-color: var(--color-accent); }
    .signup-note { font-size: 0.75em; color: var(--color-muted); margin: 0; }
    .btn-primary {
      padding: 0.7rem 1.4rem;
      background: #7c3aed;
      color: white;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-primary:hover { background: #6d28d9; }

    /* ===== Two-column digest layout ===== */
    .digest-layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 2.5rem;
      align-items: start;
      margin-bottom: 2rem;
    }

    .digest-header-row {
      display: flex; justify-content: space-between; align-items: baseline;
      border-bottom: 1px solid var(--color-border); padding-bottom: 0.75rem; margin-bottom: 1.25rem;
    }
    .digest-title { margin: 0; font-size: 1.4em; }
    .digest-date-label { font-size: 0.82em; color: var(--color-muted); margin: 0; }

    /* Locked top story */
    .locked-card {
      display: block; position: relative; background: var(--color-card);
      border: 2px solid var(--color-accent); border-radius: 10px;
      padding: 1.5rem 1.5rem 1.25rem; margin-bottom: 1.5rem;
      text-decoration: none; color: inherit; transition: box-shadow 0.2s;
    }
    .locked-card:hover { box-shadow: 0 4px 16px rgba(124,58,237,0.12); text-decoration: none; }
    .locked-card-gold { border-color: #f59e0b; }
    .locked-card-gold:hover { box-shadow: 0 4px 16px rgba(245,158,11,0.15); }
    .locked-badge {
      display: inline-block; background: var(--color-accent); color: white;
      padding: 0.15rem 0.6rem; border-radius: 4px;
      font-size: 0.68em; font-weight: 700; letter-spacing: 0.06em;
      margin-bottom: 0.6rem;
    }
    .locked-content h3 { margin: 0 0 0.4rem; font-size: 1.05em; line-height: 1.35; }
    .locked-content p { margin: 0; font-size: 0.85em; color: var(--color-muted); line-height: 1.5; }
    .locked-blur { display: none; }
    .locked-cta {
      display: inline-block; margin-top: 0.75rem;
      font-size: 0.82em; font-weight: 600; color: var(--color-accent);
    }

    /* Sketch dividers & illustrations */
    .sketch-divider { text-align: center; margin: 0.5rem 0; }
    .sketch-svg { width: 100%; max-width: 300px; height: auto; color: var(--color-fg); }
    .sketch-illustration { text-align: center; margin: 1.25rem 0; }
    .sidebar-sketch { width: 120px; height: auto; color: var(--color-fg); }

    /* Digest main content */
    .digest-scroll { line-height: 1.75; }
    .digest-scroll h2 { font-size: 1.25em; margin: 2rem 0 0.5rem; }
    .digest-scroll h3 { font-size: 1.05em; margin: 1.25rem 0 0.25rem; }
    .digest-scroll h3 a { color: var(--color-accent); }
    .digest-scroll p { font-size: 0.92em; color: #555; margin-bottom: 0.6rem; }
    .digest-scroll em { color: var(--color-muted); }
    .digest-scroll hr { border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0; }
    .digest-scroll blockquote {
      border-left: 3px solid var(--color-accent); margin: 1rem 0; padding: 0.5rem 1rem;
      font-style: italic; color: var(--color-muted); background: rgba(124,58,237,0.03); border-radius: 0 6px 6px 0;
    }
    .digest-scroll details {
      background: var(--color-card); border: 1px solid var(--color-border);
      border-radius: 8px; margin: 0.75rem 0; overflow: hidden;
    }
    .digest-scroll details:hover { border-color: #d0cec8; }
    .digest-scroll summary {
      padding: 1rem 1.25rem; cursor: pointer; list-style: none;
      font-size: 0.92em; line-height: 1.5; color: var(--color-fg); user-select: none;
    }
    .digest-scroll summary::-webkit-details-marker { display: none; }
    .digest-scroll summary::before { content: '+ '; color: var(--color-muted); font-weight: 400; }
    .digest-scroll details[open] summary::before { content: '- '; color: var(--color-accent); }
    .digest-scroll details > p,
    .digest-scroll details > blockquote { padding: 0 1.25rem; margin-bottom: 0.75rem; }
    .digest-scroll details > p:last-child { padding-bottom: 1.25rem; }

    /* ===== Right sidebar ===== */
    .digest-sidebar { font-size: 0.9em; }
    .sidebar-sticky { position: sticky; top: 2rem; }
    .sidebar-label {
      font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--color-muted); margin: 0 0 0.75rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border); font-family: 'Inter', sans-serif; font-weight: 600;
    }

    .sidebar-card {
      display: block; padding: 0.85rem 0; border-bottom: 1px solid var(--color-border);
      text-decoration: none; color: inherit; transition: opacity 0.15s;
    }
    .sidebar-card:hover { opacity: 0.75; text-decoration: none; }
    .sidebar-card strong { display: block; font-size: 0.88em; margin-bottom: 0.15rem; color: var(--color-fg); }
    .sidebar-card p { margin: 0; font-size: 0.8em; color: var(--color-muted); line-height: 1.45; }

    .sidebar-upgrade {
      display: block; background: var(--color-accent); color: white;
      padding: 1rem 1.1rem; border-radius: 8px; text-decoration: none;
      margin-top: 1.25rem; transition: opacity 0.15s;
    }
    .sidebar-upgrade:hover { opacity: 0.92; text-decoration: none; }
    .sidebar-upgrade strong { display: block; font-size: 0.95em; margin-bottom: 0.1rem; }
    .sidebar-upgrade span { font-size: 0.82em; opacity: 0.85; }
    .sidebar-upgrade p { margin: 0.4rem 0 0; font-size: 0.78em; opacity: 0.75; line-height: 1.4; }
    .sidebar-upgrade-gold { background: #f59e0b; }

    /* Source cards — Leverage style */
    .source-cards { margin-top: 2rem; }
    .source-cards-header {
      padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); margin-bottom: 0.75rem;
    }
    .source-cards-label {
      font-size: 1.05em; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--color-fg); margin: 0 0 0.15rem; font-family: 'Inter', sans-serif; font-weight: 700;
    }
    .source-cards-sub {
      font-size: 0.82em; color: var(--color-muted); margin: 0; font-style: italic;
    }
    .source-card {
      display: flex; align-items: center; gap: 1rem;
      padding: 1.1rem 0; border-bottom: 1px solid var(--color-border);
      text-decoration: none; color: inherit; transition: opacity 0.15s;
    }
    .source-card:first-of-type { border-top: 1px solid var(--color-border); }
    .source-card:hover { opacity: 0.75; text-decoration: none; }
    .source-card-text { flex: 1; min-width: 0; }
    .source-card-text strong {
      display: block; font-size: 1em; font-family: 'Merriweather', serif;
      margin-bottom: 0.2rem; color: var(--color-fg); line-height: 1.35;
    }
    .source-card-text p {
      margin: 0; font-size: 0.85em; color: var(--color-muted); line-height: 1.45;
    }
    .source-meta {
      display: block; margin-top: 0.3rem;
      font-size: 0.72em; color: var(--color-muted); opacity: 0.7;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .source-card-sketch {
      width: 80px; height: 80px; flex-shrink: 0; color: var(--color-fg); opacity: 0.2;
    }

    /* Previous digest card */
    .prev-digest-card {
      display: block; margin-top: 1.5rem; padding: 1.25rem;
      background: var(--color-card); border: 1px solid var(--color-border);
      border-radius: 8px; text-decoration: none; color: inherit;
      opacity: 0.6; transition: opacity 0.15s;
    }
    .prev-digest-card:hover { opacity: 0.85; text-decoration: none; }
    .prev-digest-date {
      display: block; font-size: 0.7em; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--color-muted); margin-bottom: 0.3rem;
    }
    .prev-digest-card strong { display: block; font-size: 0.95em; margin-bottom: 0.25rem; }
    .prev-digest-card p { margin: 0; font-size: 0.82em; color: var(--color-muted); line-height: 1.45; }
    .prev-digest-link {
      display: block; margin-top: 0.5rem; font-size: 0.8em;
      color: var(--color-accent); font-weight: 600;
    }

    @media (max-width: 768px) {
      .source-card-sketch { width: 60px; height: 60px; }
    }

    /* About — minimal */
    .about { padding: 2rem 0; border-top: 1px solid var(--color-border); margin-top: 1rem; }
    .about-text { max-width: 580px; margin: 0 auto; text-align: center; }
    .about-text p { font-size: 0.9em; color: var(--color-muted); line-height: 1.6; margin: 0; }

    .subscribed-section { padding: 2rem 0; border-top: 1px solid var(--color-border); margin-top: 1rem; }
    .subscribed-text { max-width: 580px; margin: 0 auto; text-align: center; }
    .subscribed-text p { font-size: 0.95em; color: var(--color-fg); line-height: 1.6; margin: 0; font-weight: 500; }

    .site-footer { text-align: center; padding: 2rem 0; font-size: 0.82em; color: var(--color-muted); }
    .no-content { text-align: center; padding: 3rem; color: var(--color-muted); }

    /* === Welcome Modal === */
    .modal-overlay {
      display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
      z-index: 9999; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-overlay.active { display: flex; }
    .modal-card {
      background: var(--color-card); border-radius: 14px; padding: 2.25rem 2rem 1.75rem;
      max-width: 480px; width: 100%; position: relative;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes modalSlideUp { from { transform: translateY(48px) scale(0.97); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    .modal-animate { opacity: 0; animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .modal-x { position: absolute; top: 1.1rem; right: 1.25rem; background: none; border: none; color: #bbb; font-size: 1.4em; cursor: pointer; line-height: 1; padding: 0; z-index: 1; }
    .modal-x:hover { color: #333; }

    .modal-welcome { padding: 1.5rem 2rem 1.75rem; max-width: 440px; }

    .modal-sketch { text-align: center; margin-bottom: 0.5rem; }
    .modal-sketch-svg { width: 180px; height: auto; color: var(--color-fg); opacity: 0.15; }

    .modal-welcome-body { text-align: center; margin-bottom: 1.25rem; }
    .modal-welcome-heading {
      font-size: 1.6em; margin: 0 0 0.5rem; color: var(--color-fg);
      font-family: 'Merriweather', serif; line-height: 1.25;
    }
    .modal-welcome-sub {
      font-size: 0.95em; color: var(--color-muted); line-height: 1.55; margin: 0 0 0.75rem;
    }
    .modal-email-line { font-size: 0.82em; color: var(--color-accent); font-weight: 500; margin: 0; }

    .modal-welcome-divider { height: 1px; background: var(--color-border); margin: 0 0 1.25rem; }
    .modal-pro-box { background: rgba(124,58,237,0.04); border: 1.5px solid var(--color-accent); border-radius: 10px; padding: 1.1rem 1.25rem; margin-bottom: 1rem; }
    .modal-pro-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .modal-pro-badge { background: var(--color-accent); color: white; padding: 0.2rem 0.7rem; border-radius: 20px; font-size: 0.75em; font-weight: 600; }
    .modal-pro-sub { font-size: 0.78em; color: var(--color-muted); }
    .modal-pro-list { list-style: none; padding: 0; margin: 0 0 0.85rem; }
    .modal-pro-list li { font-size: 0.83em; color: #444; padding: 0.2rem 0; }
    .modal-pro-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 600; }
    .modal-pro-btn { display: block; width: 100%; text-align: center; background: var(--color-accent); color: white; padding: 0.7rem; border-radius: 7px; font-size: 0.88em; font-weight: 600; text-decoration: none; }
    .modal-pro-btn:hover { background: var(--color-accent-hover); text-decoration: none; }
    .modal-inbox-note { text-align: center; font-size: 0.82em; color: var(--color-muted); margin: 0 0 0.5rem; }
    .modal-close-btn { display: block; width: 100%; padding: 0.65rem; background: transparent; color: var(--color-muted); border: 1px solid var(--color-border); border-radius: 7px; font-size: 0.84em; cursor: pointer; font-family: 'Inter', sans-serif; }
    .modal-close-btn:hover { color: var(--color-fg); border-color: #ccc; }

    /* Responsive */
    @media (max-width: 768px) {
      .digest-layout { grid-template-columns: 1fr; }
      .digest-sidebar { order: -1; }
      .sidebar-sticky { position: static; }
      .signup-form { flex-direction: column; }
      h1 { font-size: 2.2em; }
      .source-card-sketch { width: 50px; height: 50px; }
      .logos-slide { gap: 1.5rem; }
      .modal-card { padding: 1.25rem 1rem 1rem; }
    }
    @media (max-width: 480px) {
      h1 { font-size: 1.8em; }
      .source-card-sketch { width: 40px; height: 40px; }
      .logos-slide { gap: 1rem; }
      .modal-card { padding: 1rem 0.85rem 0.85rem; max-width: 95vw; }
      .modal-welcome-heading { font-size: 1.1em; }
    }
  </style>

  <script>
    // Handle Stripe checkout success redirect
    (async function() {
      var params = new URLSearchParams(window.location.search);
      if (params.get('upgraded') === 'true' && params.get('session_id')) {
        try {
          var res = await fetch(window.API_URL + '/api/checkout/verify', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ session_id: params.get('session_id') })
          });
          var data = await res.json();
          if (data.success) {
            // Track upgrade event
            if (window.plausible) window.plausible('Upgrade', {props: {tier: data.tier}});
            // Update localStorage with new tier
            localStorage.setItem('ae_tier', data.tier);
            if (data.email) localStorage.setItem('ae_email', data.email);
            // Clean URL and reload to reflect new tier
            window.history.replaceState({}, '', '/');
            window.location.reload();
            return;
          }
        } catch (e) {
          console.error('Checkout verify failed:', e);
        }
      }
    })();

    // Tier-based content gating
    (function() {
      var tier = localStorage.getItem('ae_tier');
      var label = document.getElementById('sidebar-cards-label');
      var upgradeCard = document.getElementById('sidebar-upgrade');
      var goldCard = document.getElementById('sidebar-upgrade-gold');
      var topCard = document.getElementById('locked-top-card');

      var topFree = document.getElementById('locked-top-free');
      var topPro = document.getElementById('locked-top-pro');
      var topInner = document.getElementById('locked-top-inner');

      if (tier === 'free' || !tier) {
        // FREE: Show Pro article as locked, mix of pro+founding sidebar cards
        // All defaults from HTML are correct
      }

      else if (tier === 'pro') {
        // PRO: Show FOUNDING article as top card (different content, upsell to Inner Circle)
        // Sidebar: hide pro cards, show only founding cards → /upgrade?tier=inner
        if (topFree) topFree.style.display = 'none';
        if (topPro) topPro.style.display = 'block';
        if (label) label.textContent = 'Inner Circle Only';
        document.querySelectorAll('.tier-pro-card').forEach(function(c) { c.style.display = 'none'; });
        if (upgradeCard) upgradeCard.style.display = 'none';
        if (goldCard) goldCard.style.display = 'block';
      }

      else if (tier === 'inner') {
        // INNER CIRCLE: Show founding article unlocked, sidebar cards link to real articles
        if (topFree) topFree.style.display = 'none';
        if (topInner) topInner.style.display = 'block';
        if (label) label.textContent = 'Your Inner Circle Content';
        document.querySelectorAll('.tier-pro-card').forEach(function(c) { c.style.display = 'none'; });
        document.querySelectorAll('.tier-founding-card').forEach(function(c) {
          var url = c.dataset.article;
          if (url) c.href = url;
        });
        if (upgradeCard) upgradeCard.style.display = 'none';
        if (goldCard) goldCard.style.display = 'none';
      }
    })();

    // Signup form
    document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('signup-email');
      const email = emailInput.value;
      const btn = document.getElementById('signup-btn');

      btn.textContent = 'Joining...';
      btn.disabled = true;

      let data;
      try {
        const res = await fetch(window.API_URL + '/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        data = await res.json();

        // Dev mode: follow the link directly
        if (data.dev_link) {
          window.location.href = data.dev_link;
          return;
        }

        if (!data.success) {
          btn.textContent = 'Something went wrong. Try again.';
          btn.style.background = '#ef4444';
          btn.disabled = false;
          setTimeout(() => { btn.textContent = 'Join for free'; btn.style.background = ''; }, 3000);
          return;
        }
      } catch (err) {
        btn.textContent = 'Connection error. Try again.';
        btn.style.background = '#ef4444';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = 'Join for free'; btn.style.background = ''; }, 3000);
        return;
      }

      // Show welcome modal
      document.getElementById('modal-email').textContent = email;
      document.getElementById('welcome-modal').classList.add('active');
      if (window.plausible) window.plausible('Signup', {props: {email: email}});

      // Update signup box
      emailInput.style.display = 'none';
      btn.textContent = "Check your inbox";
      btn.style.background = '#7c3aed';
      btn.style.color = 'white';
      btn.disabled = true;
      btn.style.opacity = '1';
      btn.style.cursor = 'default';

      const aboutEl = document.getElementById('about-section');
      const subscribedEl = document.getElementById('subscribed-section');
      if (aboutEl) aboutEl.style.display = 'none';
      if (subscribedEl) subscribedEl.style.display = 'block';
    });

    // Close modal handlers
    function closeModal() {
      document.getElementById('welcome-modal').classList.remove('active');
    }
    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-x')?.addEventListener('click', closeModal);
    document.getElementById('welcome-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeModal();
    });
  </script>
</BaseLayout>
