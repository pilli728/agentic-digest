        <a href="/upgrade" class="modal-upgrade-card">
          <div class="upgrade-badge">Pro</div>
          <strong>$12/mo</strong>
          <p>Full source list, community, early access</p>
        </a>
        <a href="/upgrade?tier=inner" class="modal-upgrade-card gold">
          <div class="upgrade-badge gold">Inner Circle</div>
          <strong>$39/mo</strong>
          <p>Templates, agents, scripts, DM access</p>
        </a>
