---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Choose Your Plan" description="Pick the level of access that fits how you build.">
  <div class="upgrade-page">
    <header class="upgrade-header">
      <a href="/" class="back-link">← Back to Agentic Edge</a>
      <h1>Choose your plan</h1>
      <p>Everyone gets the analysis. Pick how deep you want to go.</p>
    </header>

    <div class="pricing-section">
      <!-- Free — shows what you're missing -->
      <div class="plan-card free-plan">
        <h2>Free</h2>
        <p class="price">$0</p>
        <p class="price-sub">Your current plan</p>
        <ul>
          <li class="has">Weekly digest with 3 analysis sections</li>
          <li class="has">Synthesized takes on what matters</li>
          <li class="missing">15+ source links with one-liners</li>
          <li class="missing">Builder community (Discord)</li>
          <li class="missing">Behind-the-scenes of what I'm building</li>
          <li class="missing">Early access (Friday PM)</li>
          <li class="missing">CLAUDE.md templates and agent configs</li>
          <li class="missing">Step-by-step guides on how I use agents</li>
          <li class="missing">Access to tools I'm building</li>
          <li class="missing">DM me directly — ask anything</li>
        </ul>
        <a href="/" class="checkout-btn secondary">Current plan</a>
      </div>

      <!-- Pro -->
      <div class="plan-card pro-plan">
        <div class="badge">Most Popular</div>
        <h2>Pro</h2>
        <p class="price">$12<span>/mo</span></p>
        <p class="price-sub">or $99/year (save 31%)</p>
        <ul>
          <li class="has">Weekly digest with 3 analysis sections</li>
          <li class="has">Synthesized takes on what matters</li>
          <li class="has">15+ source links with one-liners</li>
          <li class="has">Builder community (Discord)</li>
          <li class="has">Behind-the-scenes of what I'm building</li>
          <li class="has">Early access (Friday PM)</li>
          <li class="missing">CLAUDE.md templates and agent configs</li>
          <li class="missing">Step-by-step guides on how I use agents</li>
          <li class="missing">Access to tools I'm building</li>
          <li class="missing">DM me directly — ask anything</li>
        </ul>
        <button class="checkout-btn" id="checkout-pro" data-price="pro_monthly">
          Go Pro — $12/month
        </button>
      </div>

      <!-- Inner Circle -->
      <div class="plan-card inner-plan">
        <div class="badge gold">Limited spots</div>
        <h2>Inner Circle</h2>
        <p class="price">$39<span>/mo</span></p>
        <p class="price-sub">Price locked forever</p>
        <ul>
          <li class="has">Weekly digest with 3 analysis sections</li>
          <li class="has">Synthesized takes on what matters</li>
          <li class="has">15+ source links with one-liners</li>
          <li class="has">Builder community (Discord)</li>
          <li class="has">Behind-the-scenes of what I'm building</li>
          <li class="has">Early access (Friday PM)</li>
          <li class="has">CLAUDE.md templates and agent configs</li>
          <li class="has">Step-by-step guides on how I use agents</li>
          <li class="has">Access to tools I'm building</li>
          <li class="has">DM me directly — ask anything</li>
        </ul>
        <button class="checkout-btn gold" id="checkout-inner" data-price="inner_monthly">
          Join Inner Circle — $39/month
        </button>
      </div>
    </div>

    <section class="faq">
      <h2>Questions</h2>
      <div class="faq-item">
        <h3>Can I cancel anytime?</h3>
        <p>Yes. One click. You keep access until the end of your billing period.</p>
      </div>
      <div class="faq-item">
        <h3>What's in the Discord?</h3>
        <p>Builders sharing what they're shipping, tools they found, problems they solved. I'm in there daily. It's small on purpose.</p>
      </div>
      <div class="faq-item">
        <h3>What kind of DM access?</h3>
        <p>Inner Circle members can message me directly about what they're building. I'll review your CLAUDE.md, suggest tools, help debug agent setups. Response within 24 hours.</p>
      </div>
      <div class="faq-item">
        <h3>What if I don't like it?</h3>
        <p>30-day money-back guarantee. No questions. Email me and it's done.</p>
      </div>
    </section>
  </div>

  <style>
    .upgrade-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 0;
    }

    .upgrade-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 1rem;
      font-size: 0.9em;
      color: #888;
    }

    .upgrade-header h1 {
      font-size: 2.5em;
      margin: 0 0 0.5rem 0;
    }

    .upgrade-header p {
      color: #666;
      font-size: 1.1em;
    }

    .pricing-section {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    .plan-card {
      border: 2px solid var(--color-border);
      border-radius: 12px;
      padding: 2rem 1.5rem;
      position: relative;
    }

    .plan-card.pro-plan {
      border-color: var(--color-accent);
      box-shadow: 0 4px 20px rgba(0, 102, 204, 0.1);
    }

    .plan-card.inner-plan {
      border-color: #f59e0b;
    }

    .plan-card .badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: #f59e0b;
      color: white;
      padding: 0.25rem 1rem;
      border-radius: 12px;
      font-size: 0.75em;
      font-weight: 600;
      white-space: nowrap;
    }

    .plan-card h2 {
      margin: 0 0 0.5rem 0;
    }

    .price {
      font-size: 3em;
      font-weight: 700;
      margin: 0;
    }

    .price span {
      font-size: 0.3em;
      font-weight: 400;
      color: #888;
    }

    .price-annual {
      font-size: 0.85em;
      color: #888;
      margin: 0.25rem 0 1.5rem 0;
    }

    .plan-card ul {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
    }

    .plan-card li {
      padding: 0.5rem 0;
      font-size: 0.95em;
    }

    li.has::before {
      content: "✓ ";
      color: var(--color-accent);
      font-weight: 600;
    }

    .inner-plan li.has::before {
      color: #f59e0b;
    }

    li.missing {
      color: #bbb;
      text-decoration: line-through;
      text-decoration-color: #ddd;
    }

    li.missing::before {
      content: "✗ ";
      color: #ddd;
      font-weight: 600;
    }

    .checkout-btn {
      display: block;
      width: 100%;
      padding: 1rem;
      border: none;
      border-radius: 8px;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      margin-bottom: 0.75rem;
      background: var(--color-accent);
      color: white;
      transition: opacity 0.2s;
    }

    .checkout-btn:hover {
      opacity: 0.9;
    }

    .checkout-btn.secondary {
      background: transparent;
      border: 1px solid var(--color-border);
      color: var(--color-fg);
    }

    .checkout-btn.gold {
      background: #f59e0b;
    }

    .badge.gold {
      background: #f59e0b;
    }

    .price-sub {
      font-size: 0.85em;
      color: #888;
      margin: 0.25rem 0 1.5rem 0;
    }

    @media (max-width: 900px) {
      .pricing-section { grid-template-columns: 1fr; }
    }

    /* FAQ */
    .faq h2 {
      margin-bottom: 1.5rem;
    }

    .faq-item {
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }

    .faq-item h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1em;
    }

    .faq-item p {
      margin: 0;
      color: #666;
      font-size: 0.95em;
    }

    @media (max-width: 768px) {
      .pricing-section { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    // Stripe checkout integration
    // TODO: Replace with your Stripe publishable key and price IDs
    const STRIPE_CONFIG = {
      // Set these in your .env and expose via API
      pro_monthly: 'price_XXXXX',  // Create in Stripe Dashboard
      pro_annual: 'price_XXXXX',
      founding_monthly: 'price_XXXXX',
    };

    document.querySelectorAll('.checkout-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const priceKey = btn.dataset.price;
        if (!priceKey) return;

        btn.textContent = 'Redirecting to checkout...';
        btn.disabled = true;

        try {
          // Call your API to create a Stripe Checkout session
          const res = await fetch('http://localhost:8000/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ price_key: priceKey })
          });

          const data = await res.json();

          if (data.checkout_url) {
            window.location.href = data.checkout_url;
          } else {
            alert(data.message || 'Stripe not configured yet. Add STRIPE_SECRET_KEY to .env');
            btn.textContent = btn.dataset.price.includes('founding') ? 'Become a Founding Member' : 'Start Pro';
            btn.disabled = false;
          }
        } catch (err) {
          alert('Payment system not ready yet. Coming soon!');
          btn.textContent = 'Coming Soon';
          btn.disabled = false;
        }
      });
    });

    // Check URL params for tier preselection
    const params = new URLSearchParams(window.location.search);
    if (params.get('tier') === 'founding') {
      document.getElementById('founding-plan')?.scrollIntoView({ behavior: 'smooth' });
    }
  </script>
</BaseLayout>
