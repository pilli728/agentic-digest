---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Choose Your Plan" description="Pick the level of access that fits how you build.">
  <div class="upgrade-page">
    <header class="upgrade-header">
      <a href="/" class="back-link">← Back to Agentic Edge</a>
      <h1>Choose your plan</h1>
      <p>Everyone gets the analysis. Pick how deep you want to go.</p>
    </header>

    <div class="pricing-section">
      <!-- Free -->
      <div class="plan-card free-plan" id="plan-free">
        <h2>Free</h2>
        <p class="price">$0</p>
        <p class="price-sub" id="free-sub">Your current plan</p>
        <ul>
          <li class="has">Weekly digest every Monday</li>
          <li class="missing">15+ ranked sources with one-liners</li>
          <li class="missing">Early access Friday PM</li>
          <li class="missing">The Vault</li>
          <li class="missing">Tool drops + DM access</li>
        </ul>
        <span class="checkout-btn secondary" id="free-btn" style="cursor: default;">Current plan</span>
      </div>

      <!-- Pro -->
      <div class="plan-card pro-plan" id="plan-pro">
        <div class="badge">Most Popular</div>
        <h2>Pro</h2>
        <p class="price" id="pro-price">$8<span>/mo</span></p>
        <p class="price-sub" id="pro-price-sub"><s>$12/mo</s> billed annually at $99</p>
        <ul>
          <li class="has">15+ ranked sources with one-liners</li>
          <li class="has">The Vault: playbooks, guides, breakdowns</li>
          <li class="has">Behind-the-scenes of what I'm building</li>
          <li class="missing">Tool drops + DM access</li>
        </ul>
        <div class="billing-toggle" id="pro-toggle">
          <button class="toggle-option" data-period="monthly">Monthly</button>
          <button class="toggle-option active" data-period="annual">Annual (save 31%)</button>
        </div>
        <button class="checkout-btn" id="checkout-pro" data-price="pro_monthly" style="display:none;">
          Go Pro — $12/month
        </button>
        <button class="checkout-btn" id="checkout-pro-annual" data-price="pro_annual">
          Go Pro — $99/year
        </button>
      </div>

      <!-- Inner Circle -->
      <div class="plan-card inner-plan" id="plan-inner">
        <div class="badge gold">Limited spots</div>
        <h2>Inner Circle</h2>
        <p class="price" id="inner-price">$29<span>/mo</span></p>
        <p class="price-sub" id="inner-price-sub"><s>$39/mo</s> billed annually at $349</p>
        <ul>
          <li class="has">Everything in Pro</li>
          <li class="has">Monthly tool drops (CLAUDE.md, configs, scripts)</li>
          <li class="has">DM me — get stack reviews, ask anything</li>
          <li class="has">First to see what I build before I write about it</li>
        </ul>
        <div class="billing-toggle" id="inner-toggle">
          <button class="toggle-option" data-period="monthly">Monthly</button>
          <button class="toggle-option active" data-period="annual">Annual (save 25%)</button>
        </div>
        <button class="checkout-btn gold" id="checkout-inner" data-price="inner_monthly" style="display:none;">
          Join Inner Circle — $39/month
        </button>
        <button class="checkout-btn gold" id="checkout-inner-annual" data-price="inner_annual">
          Join Inner Circle — $349/year
        </button>
      </div>
    </div>

    <div class="plan-footer">
      <p class="cancel-link" id="cancel-link" style="display:none"><a href="#" id="cancel-btn">Cancel subscription and downgrade to free</a></p>
      <p class="unsubscribe-link"><a href="/unsubscribe">Unsubscribe from all emails</a></p>
    </div>
  </div>

  <style>
    .upgrade-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 0;
    }

    .upgrade-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 1rem;
      font-size: 0.9em;
      color: #888;
    }

    .upgrade-header h1 {
      font-size: 2.5em;
      margin: 0 0 0.5rem 0;
    }

    .upgrade-header p {
      color: #666;
      font-size: 1.1em;
    }

    .pricing-section {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    .plan-card {
      border: 2px solid var(--color-border);
      border-radius: 12px;
      padding: 1.25rem 1.25rem;
      position: relative;
    }

    .plan-card.pro-plan {
      border-color: var(--color-accent);
      box-shadow: 0 4px 20px rgba(0, 102, 204, 0.1);
    }

    .plan-card.inner-plan {
      border-color: #f59e0b;
    }

    .plan-card .badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: #f59e0b;
      color: white;
      padding: 0.25rem 1rem;
      border-radius: 12px;
      font-size: 0.75em;
      font-weight: 600;
      white-space: nowrap;
    }

    .plan-card h2 {
      margin: 0 0 0.5rem 0;
    }

    .price {
      font-size: 2.2em;
      font-weight: 700;
      margin: 0;
    }

    .price span {
      font-size: 0.3em;
      font-weight: 400;
      color: #888;
    }

    .price-annual {
      font-size: 0.85em;
      color: #888;
      margin: 0.25rem 0 1.5rem 0;
    }

    .plan-card ul {
      list-style: none;
      padding: 0;
      margin: 0.75rem 0;
    }

    .plan-card li {
      padding: 0.3rem 0;
      font-size: 0.88em;
    }

    li.has::before {
      content: "✓ ";
      color: var(--color-accent);
      font-weight: 600;
    }

    .inner-plan li.has::before {
      color: #f59e0b;
    }

    li.missing {
      color: #bbb;
      text-decoration: line-through;
      text-decoration-color: #ddd;
    }

    li.missing::before {
      content: "✗ ";
      color: #ddd;
      font-weight: 600;
    }

    .checkout-btn {
      display: block;
      width: 100%;
      padding: 0.7rem;
      border: none;
      border-radius: 8px;
      font-size: 0.9em;
      font-weight: 600;
      cursor: pointer;
      margin-bottom: 0;
      background: var(--color-accent);
      color: white;
      transition: opacity 0.2s;
    }

    .checkout-btn:hover {
      opacity: 0.9;
    }

    .checkout-btn.secondary {
      background: transparent;
      border: 1px solid var(--color-border);
      color: var(--color-fg);
    }

    .checkout-btn.gold {
      background: #f59e0b;
    }

    .billing-toggle {
      display: flex;
      background: #f0f0f0;
      border-radius: 24px;
      padding: 3px;
      margin-bottom: 0.75rem;
      gap: 2px;
    }

    .toggle-option {
      flex: 1;
      padding: 0.45rem 0.75rem;
      border: none;
      background: transparent;
      font-size: 0.78em;
      font-weight: 600;
      cursor: pointer;
      color: #888;
      border-radius: 22px;
      transition: all 0.2s;
    }

    .toggle-option:hover {
      color: #555;
    }

    .toggle-option.active {
      background: var(--color-accent);
      color: white;
      box-shadow: 0 1px 4px rgba(124,58,237,0.25);
    }

    .badge.gold {
      background: #f59e0b;
    }

    .price-sub {
      font-size: 0.8em;
      color: #888;
      margin: 0.15rem 0 0.5rem 0;
    }
    .price-sub s {
      color: #bbb;
      text-decoration: line-through;
      margin-right: 0.25em;
    }

    @media (max-width: 900px) {
      .pricing-section { grid-template-columns: 1fr; }
    }

    /* FAQ */
    .faq h2 {
      margin-bottom: 1.5rem;
    }

    .faq-item {
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }

    .faq-item h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1em;
    }

    .faq-item p {
      margin: 0;
      color: #666;
      font-size: 0.95em;
    }

    .plan-footer { text-align: center; margin-top: 2rem; }
    .cancel-link { font-size: 0.8em; margin-bottom: 0.5rem; }
    .cancel-link a { color: #ef4444; text-decoration: none; }
    .cancel-link a:hover { text-decoration: underline; }
    .unsubscribe-link { font-size: 0.72em; }
    .unsubscribe-link a { color: #bbb; text-decoration: none; }
    .unsubscribe-link a:hover { color: #888; text-decoration: underline; }

    .current-plan-btn {
      background: var(--color-accent) !important; color: white !important;
      opacity: 1 !important; cursor: default !important;
      border: none !important;
    }

    @media (max-width: 768px) {
      .pricing-section { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .upgrade-page { padding: 1rem 0; }
      .upgrade-page h1 { font-size: 1.5em; }
      .price { font-size: 1.8em; }
      .plan-card { padding: 1rem; }
    }
  </style>

  <script>
    // Dynamic plan state based on user tier
    (function() {
      const sid = localStorage.getItem('ae_session');
      const tier = localStorage.getItem('ae_tier') || 'free';

      if (sid && (tier === 'pro' || tier === 'inner')) {
        // Verify with server and update
        fetch(window.API_URL + '/api/auth/session', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ session_id: sid })
        }).then(r => r.json()).then(data => {
          if (data.success) applyTier(data.tier);
          else applyTier('free');
        }).catch(() => applyTier(tier));
      } else {
        applyTier(tier);
      }

      function applyTier(t) {
        const freeBtn = document.getElementById('free-btn');
        const freeSub = document.getElementById('free-sub');
        const proBtn = document.getElementById('checkout-pro');
        const innerBtn = document.getElementById('checkout-inner');

        const proAnnualBtn = document.getElementById('checkout-pro-annual');
        const innerAnnualBtn = document.getElementById('checkout-inner-annual');
        const proToggle = document.getElementById('pro-toggle');
        const innerToggle = document.getElementById('inner-toggle');

        if (t === 'pro') {
          if (freeBtn) { freeBtn.textContent = 'Free plan'; freeBtn.classList.remove('secondary'); freeBtn.style.opacity = '0.5'; }
          if (freeSub) freeSub.textContent = '';
          if (proBtn) { proBtn.textContent = 'Current plan'; proBtn.disabled = true; proBtn.classList.add('current-plan-btn'); }
          if (proAnnualBtn) { proAnnualBtn.textContent = 'Switch to annual — $99/year'; proAnnualBtn.disabled = false; }
        } else if (t === 'inner') {
          if (freeBtn) { freeBtn.textContent = 'Free plan'; freeBtn.classList.remove('secondary'); freeBtn.style.opacity = '0.5'; }
          if (freeSub) freeSub.textContent = '';
          // Gray out entire Pro card
          if (proBtn) { proBtn.textContent = 'Included in Inner Circle'; proBtn.disabled = true; proBtn.style.opacity = '0.5'; }
          if (proAnnualBtn) { proAnnualBtn.textContent = 'Included in Inner Circle'; proAnnualBtn.disabled = true; proAnnualBtn.style.opacity = '0.5'; }
          if (proToggle) proToggle.style.display = 'none';
          var proCard = document.getElementById('plan-pro');
          if (proCard) proCard.style.opacity = '0.6';
          // Inner: current monthly, allow switch to annual
          if (innerBtn) { innerBtn.textContent = 'Current plan'; innerBtn.disabled = true; innerBtn.classList.add('current-plan-btn'); innerBtn.classList.remove('gold'); }
          if (innerAnnualBtn) { innerAnnualBtn.textContent = 'Switch to annual — $349/year'; innerAnnualBtn.disabled = false; }
        }
        // else free: default state already correct
      }
      function applyCancel(t) {
        if (t === 'pro' || t === 'inner') {
          document.getElementById('cancel-link').style.display = 'block';
        }
      }
      applyCancel(tier);

      // Cancel subscription handler
      document.getElementById('cancel-btn')?.addEventListener('click', async (e) => {
        e.preventDefault();
        if (!confirm('Are you sure you want to cancel? You will retain access until the end of your current billing period.')) return;
        const cancelSid = localStorage.getItem('ae_session');
        if (!cancelSid) return;
        try {
          const res = await fetch(window.API_URL + '/api/cancel-subscription', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ session_id: cancelSid })
          });
          const data = await res.json();
          if (data.success) {
            localStorage.setItem('ae_tier', 'free');
            window.location.reload();
          } else {
            document.getElementById('cancel-btn').textContent = data.message || 'Error cancelling';
          }
        } catch {
          document.getElementById('cancel-btn').textContent = 'Connection error';
        }
      });
    })();

    // Billing toggle for Pro and Inner Circle
    var toggleConfig = {
      'pro-toggle': {
        monthlyBtn: 'checkout-pro', annualBtn: 'checkout-pro-annual',
        priceEl: 'pro-price', subEl: 'pro-price-sub',
        monthlyPrice: '$12<span>/mo</span>', monthlySub: 'billed monthly',
        annualPrice: '$8<span>/mo</span>', annualSub: '<s>$12/mo</s> billed annually at $99',
      },
      'inner-toggle': {
        monthlyBtn: 'checkout-inner', annualBtn: 'checkout-inner-annual',
        priceEl: 'inner-price', subEl: 'inner-price-sub',
        monthlyPrice: '$39<span>/mo</span>', monthlySub: 'billed monthly',
        annualPrice: '$29<span>/mo</span>', annualSub: '<s>$39/mo</s> billed annually at $349',
      }
    };

    document.querySelectorAll('.billing-toggle').forEach(function(toggle) {
      var cfg = toggleConfig[toggle.id];
      if (!cfg) return;

      toggle.querySelectorAll('.toggle-option').forEach(function(opt) {
        opt.addEventListener('click', function() {
          toggle.querySelectorAll('.toggle-option').forEach(function(o) { o.classList.remove('active'); });
          opt.classList.add('active');
          var isAnnual = opt.dataset.period === 'annual';
          var mBtn = document.getElementById(cfg.monthlyBtn);
          var aBtn = document.getElementById(cfg.annualBtn);
          var priceEl = document.getElementById(cfg.priceEl);
          var subEl = document.getElementById(cfg.subEl);
          if (mBtn) mBtn.style.display = isAnnual ? 'none' : 'block';
          if (aBtn) aBtn.style.display = isAnnual ? 'block' : 'none';
          if (priceEl) priceEl.innerHTML = isAnnual ? cfg.annualPrice : cfg.monthlyPrice;
          if (subEl) subEl.innerHTML = isAnnual ? cfg.annualSub : cfg.monthlySub;
        });
      });
    });

    document.querySelectorAll('.checkout-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const priceKey = btn.dataset.price;
        if (!priceKey) return;

        btn.textContent = 'Redirecting to checkout...';
        btn.disabled = true;

        try {
          const checkoutBody = { price_key: priceKey };
          const sid = localStorage.getItem('ae_session');
          if (sid) checkoutBody.session_id = sid;

          const res = await fetch(window.API_URL + '/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(checkoutBody)
          });

          const data = await res.json();

          if (data.checkout_url) {
            if (window.plausible) window.plausible('Checkout', {props: {plan: priceKey}});
            window.location.href = data.checkout_url;
          } else {
            alert(data.message || 'Payment system is temporarily unavailable. Please try again later.');
            btn.textContent = btn.dataset.price.includes('founding') ? 'Become a Founding Member' : 'Start Pro';
            btn.disabled = false;
          }
        } catch (err) {
          alert('Payment system not ready yet. Coming soon!');
          btn.textContent = 'Coming Soon';
          btn.disabled = false;
        }
      });
    });

    // Check URL params for tier preselection
    const params = new URLSearchParams(window.location.search);
    const tierParam = params.get('tier');
    if (tierParam === 'inner' || tierParam === 'founding') {
      const innerCard = document.querySelector('.inner-plan');
      if (innerCard) {
        innerCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        innerCard.style.boxShadow = '0 0 0 3px #f59e0b';
        setTimeout(() => { innerCard.style.boxShadow = ''; }, 2000);
      }
    }
  </script>
</BaseLayout>
