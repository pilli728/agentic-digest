---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const templates: Record<string, { file: string; title: string; description: string; lang: string }> = {
  'claude-md':            { file: 'CLAUDE.md',                title: 'CLAUDE.md',              description: 'Project context for Claude Code. Drop this in your repo root.',            lang: 'markdown' },
  'agents-md':            { file: 'AGENTS.md',                title: 'AGENTS.md',              description: 'Constraints, danger zones, verification steps. Not a tech stack list.',   lang: 'markdown' },
  'react-agent':          { file: 'react-agent-CLAUDE.md',    title: 'React Agent CLAUDE.md',  description: 'Next.js + Claude API + Prisma. Pre-configured for agent projects.',       lang: 'markdown' },
  'python-agent':         { file: 'python-agent-CLAUDE.md',   title: 'Python Agent CLAUDE.md', description: 'FastAPI + SQLAlchemy + Claude. Agent rules baked in.',                    lang: 'markdown' },
  'skill-code-review':    { file: 'SKILLS-code-review.md',    title: 'Code Review Skill',      description: 'Security, performance, readability. Drop into .claude/skills/',           lang: 'markdown' },
  'skill-security-audit': { file: 'SKILLS-security-audit.md', title: 'Security Audit Skill',   description: 'OWASP Top 10 checklist as a Claude skill. Catches what you miss.',        lang: 'markdown' },
  'skill-test-writer':    { file: 'SKILLS-test-writer.md',    title: 'Test Writer Skill',      description: 'Edge cases, failure modes, AAA pattern. Makes Claude write real tests.',  lang: 'markdown' },
  'pre-commit-hook':      { file: 'pre-commit-hook.sh',       title: 'Pre-Commit Hook',        description: 'Tests, lint, typecheck, secret scan. Nothing broken gets committed.',     lang: 'bash'     },
};

export function getStaticPaths() {
  return [
    'claude-md', 'agents-md', 'react-agent', 'python-agent',
    'skill-code-review', 'skill-security-audit', 'skill-test-writer', 'pre-commit-hook',
  ].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const meta = templates[slug];
if (!meta) return Astro.redirect('/pro');

const content = readFileSync(join(process.cwd(), 'src/data/downloads', meta.file), 'utf-8');
---

<BaseLayout title={`${meta.title} — The Vault`}>
  <!-- Auth gate -->
  <div class="auth-gate" id="auth-gate">
    <div class="gate-card">
      <h2>Inner Circle Only</h2>
      <p>Copy-paste templates are available to Inner Circle members.</p>
      <a href="/upgrade?tier=inner" class="gate-btn">Upgrade to Inner Circle</a>
      <p class="gate-sub">Already a member? <a href="/login">Sign in</a></p>
    </div>
  </div>

  <div id="template-content" style="display:none">
    <header class="tmpl-header">
      <a href="/pro" class="back-link">← The Vault</a>
      <div class="tmpl-meta">
        <span class="tier-badge">Inner Circle</span>
      </div>
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </header>

    <div class="code-block">
      <div class="code-toolbar">
        <span class="code-lang">{meta.lang}</span>
        <button class="copy-btn" id="copy-btn">Copy</button>
      </div>
      <pre id="code-content"><code set:text={content} /></pre>
    </div>
  </div>

  <style>
    .tmpl-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
    .back-link { display: inline-block; margin-bottom: 1rem; font-size: 0.9em; color: #888; text-decoration: none; }
    .back-link:hover { color: var(--color-accent); }
    .tmpl-meta { margin-bottom: 0.75rem; }
    .tier-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.75em; font-weight: 600;
      background: rgba(245,158,11,0.1); color: #b45309;
    }
    h1 { font-size: 1.8em; margin: 0 0 0.4rem; }
    .tmpl-header p { color: #666; margin: 0; }

    .code-block {
      border: 1px solid var(--color-border);
      border-radius: 10px;
      overflow: hidden;
    }
    .code-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 1rem;
      background: #f5f5f5;
      border-bottom: 1px solid var(--color-border);
    }
    .code-lang { font-size: 0.75em; color: #888; font-family: monospace; }
    .copy-btn {
      background: var(--color-accent);
      color: white;
      border: none;
      padding: 0.35rem 1rem;
      border-radius: 6px;
      font-size: 0.8em;
      font-weight: 600;
      cursor: pointer;
    }
    .copy-btn:hover { opacity: 0.85; }
    .copy-btn.copied { background: #16a34a; }
    pre {
      margin: 0;
      padding: 1.5rem;
      overflow-x: auto;
      font-size: 0.85em;
      line-height: 1.6;
      background: #fafafa;
      font-family: 'Menlo', 'Monaco', monospace;
      white-space: pre;
    }
    code { background: none; padding: 0; }

    /* Auth gate */
    .auth-gate { max-width: 400px; margin: 4rem auto; text-align: center; }
    .gate-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 2.5rem; }
    .gate-card h2 { margin: 0 0 0.5rem; font-size: 1.5em; }
    .gate-card > p { color: #666; font-size: 0.92em; margin: 0 0 1.5rem; }
    .gate-btn {
      display: inline-block; background: #f59e0b; color: white;
      padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;
      text-decoration: none; font-size: 0.95em;
    }
    .gate-btn:hover { opacity: 0.9; text-decoration: none; }
    .gate-sub { font-size: 0.82em; color: #888; margin: 1rem 0 0; }
    .gate-sub a { color: var(--color-accent); }
  </style>

  <script>
    const API = window.API_URL;
    const sid = localStorage.getItem('ae_session');

    function show() {
      document.getElementById('auth-gate').style.display = 'none';
      document.getElementById('template-content').style.display = 'block';
    }
    function hide() {
      document.getElementById('auth-gate').style.display = 'block';
      document.getElementById('template-content').style.display = 'none';
    }

    if (sid) {
      const cached = localStorage.getItem('ae_tier');
      if (cached === 'inner') show();

      fetch(`${API}/api/auth/session`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: sid })
      }).then(r => r.json()).then(data => {
        if (data.success && data.tier === 'inner') {
          localStorage.setItem('ae_tier', data.tier);
          show();
        } else {
          hide();
        }
      }).catch(() => {});
    } else {
      hide();
    }

    document.getElementById('copy-btn')?.addEventListener('click', () => {
      const text = document.getElementById('code-content')?.textContent ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-btn') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    });
  </script>
</BaseLayout>
