---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const premium = await getCollection('premium');
  const now = new Date();
  const parseLocal = (s) => { const [y,m,d] = s.split('-').map(Number); return new Date(y, m-1, d); };
  const published = premium.filter(p => parseLocal(p.data.date) <= now);
  return published.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Extract first 3 non-empty prose paragraphs for the teaser
function extractTeaser(body: string): string[] {
  const lines = body.split('\n');
  const paragraphs: string[] = [];
  let current = '';
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (current) { paragraphs.push(current); current = ''; }
      if (paragraphs.length >= 3) break;
    } else if (!trimmed.startsWith('#') && !trimmed.startsWith('---') && !trimmed.startsWith('|')) {
      current += (current ? ' ' : '') + trimmed;
    }
  }
  if (current && paragraphs.length < 3) paragraphs.push(current);
  return paragraphs.slice(0, 3);
}
const teaserParagraphs = extractTeaser(entry.body || '');
---

<BaseLayout title={entry.data.title}>
  <!-- Teaser for non-authenticated users (only for paid articles) -->
  {entry.data.tier !== 'free' && !entry.data.featured_free && (
  <div class="article-teaser" id="article-teaser">
    <header class="article-header">
      <a href="/pro" class="back-link">← The Vault</a>
      <div class="article-meta">
        <span class={`tier-badge ${entry.data.tier}`}>{entry.data.tier === 'founding' ? 'Founding Only' : 'Pro'}</span>
        <span class="category">{entry.data.category}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>
    </header>
    <div class="teaser-body">
      {teaserParagraphs.map(para => <p>{para}</p>)}
      <div class="teaser-fade"></div>
    </div>
    <div class="paywall-prompt">
      <p class="paywall-heading">Continue reading in The Vault</p>
      <p class="paywall-sub">This article is available to {entry.data.tier === 'founding' ? 'Inner Circle' : 'Pro'} members.</p>
      <a href="/upgrade" class="gate-btn">Unlock access →</a>
      <p class="gate-sub">Already a member? <a href="/login">Sign in</a></p>
    </div>
  </div>
  )}

  <!-- Auth gate (shown when session is invalid/expired) -->
  <div class="auth-gate" id="auth-gate" style="display:none">
    <div class="gate-card">
      <h2>The Vault</h2>
      <p>This guide is available to Pro and Inner Circle members.</p>
      <a href="/login" class="gate-btn">Sign in</a>
      <p class="gate-sub">Not a member? <a href="/upgrade">See plans — $12/mo</a></p>
    </div>
  </div>

  <div id="pro-content" class="article-wrapper" style={entry.data.tier === 'free' || entry.data.featured_free ? '' : 'display:none'} data-content-tier={entry.data.tier} data-featured-free={entry.data.featured_free ? 'true' : 'false'}>
    <header class="article-header">
      <a href="/pro" class="back-link">← The Vault</a>
      <div class="article-meta">
        <span class={`tier-badge ${entry.data.tier}`}>{entry.data.tier === 'free' ? 'Free' : entry.data.tier === 'founding' ? 'Founding Only' : entry.data.featured_free ? 'Free this week' : 'Pro'}</span>
        <span class="category">{entry.data.category}</span>
        <span class="date">{entry.data.date}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>
    </header>

    <!-- Simple divider -->
    <hr class="article-hr" />

    <main class="article-content">
      <Content />
    </main>

    <!-- Bottom CTA -->
    <footer class="article-footer">
      <p class="footer-label">Want to see more articles like this?</p>
      <div class="footer-actions">
        <a href="/pro" class="footer-btn">Browse The Vault</a>
        <a href="/upgrade" class="footer-btn footer-btn-primary">Upgrade to Pro</a>
      </div>
      <p class="footer-credit">Part of the <a href="/">Agentic Edge</a> library.</p>
    </footer>
  </div>

  <style>
    /* Article layout */
    .article-wrapper { max-width: 680px; margin: 0 auto; }

    .article-header { margin-bottom: 0; padding-bottom: 1.5rem; }
    .back-link { display: inline-block; margin-bottom: 1rem; font-size: 0.88em; color: #999; text-decoration: none; }
    .back-link:hover { color: var(--color-accent); }
    .article-meta { display: flex; gap: 0.6rem; margin-bottom: 1rem; align-items: center; flex-wrap: wrap; }
    .tier-badge { padding: 0.2rem 0.65rem; border-radius: 12px; font-size: 0.72em; font-weight: 600; }
    .tier-badge.pro { background: rgba(0,102,204,0.1); color: var(--color-accent); }
    .tier-badge.founding { background: rgba(245,158,11,0.1); color: #b45309; }
    .tier-badge.free { background: rgba(34,197,94,0.1); color: #16a34a; }
    .category { padding: 0.2rem 0.65rem; border-radius: 12px; font-size: 0.72em; background: rgba(0,0,0,0.04); color: #888; }
    .date { font-size: 0.82em; color: #aaa; }
    h1 { font-size: 1.85em; line-height: 1.25; margin: 0 0 0.6rem; font-family: 'Merriweather', Georgia, serif; }
    .description { font-size: 1em; color: #777; margin: 0; line-height: 1.5; }

    /* Divider */
    .article-hr { border: none; border-top: 1px solid var(--color-border); margin: 0 0 2rem; }

    /* Article body */
    .article-content {
      margin-bottom: 2.5rem;
      font-family: 'Merriweather', Georgia, serif;
      font-size: 0.95em;
      line-height: 1.8;
      color: var(--color-fg);
    }
    .article-content h2 {
      font-size: 1.3em; margin: 2.5rem 0 0.75rem; font-weight: 700;
      padding-bottom: 0.4rem; border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .article-content h3 { font-size: 1.1em; margin: 2rem 0 0.5rem; font-weight: 600; }
    .article-content p { margin: 0 0 1.25rem; }
    .article-content ul, .article-content ol { margin: 0 0 1.25rem; padding-left: 1.5rem; }
    .article-content li { margin-bottom: 0.4rem; }
    .article-content code {
      background: rgba(0,0,0,0.04); padding: 0.15rem 0.4rem;
      border-radius: 4px; font-size: 0.88em;
    }
    .article-content pre {
      background: #f8f8f6; border: 1px solid rgba(0,0,0,0.06);
      border-radius: 8px; padding: 1.25rem; overflow-x: auto;
      font-size: 0.85em; line-height: 1.6; margin: 1.25rem 0;
    }
    .article-content pre code { background: none; padding: 0; }
    .article-content blockquote {
      border-left: 3px solid var(--color-accent); margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1.25rem; color: #555; font-style: italic;
    }
    .article-content table { width: 100%; border-collapse: collapse; margin: 1.25rem 0; font-size: 0.9em; }
    .article-content th, .article-content td { padding: 0.6rem 0.75rem; border-bottom: 1px solid rgba(0,0,0,0.06); text-align: left; }
    .article-content th { font-weight: 600; font-size: 0.85em; color: #666; text-transform: uppercase; letter-spacing: 0.04em; }
    .article-content a { color: var(--color-accent); text-decoration: none; }
    .article-content a:hover { text-decoration: underline; }
    .article-content strong { font-weight: 600; }

    /* Footer */
    .article-footer {
      text-align: center; padding: 2rem 0 1rem;
      border-top: 1px solid var(--color-border);
    }
    .footer-label { font-size: 1.05em; font-weight: 600; margin: 0 0 1rem; color: var(--color-fg); }
    .footer-actions { display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .footer-btn {
      padding: 0.6rem 1.5rem; border-radius: 8px; font-size: 0.88em; font-weight: 600;
      text-decoration: none; border: 1px solid var(--color-border); color: var(--color-fg);
    }
    .footer-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
    .footer-btn-primary { background: var(--color-accent); color: white; border-color: var(--color-accent); }
    .footer-btn-primary:hover { opacity: 0.9; color: white; }
    .footer-credit { font-size: 0.8em; color: #bbb; margin: 0; }
    .footer-credit a { color: #bbb; }
    /* Teaser */
    .article-teaser { max-width: 760px; }
    .teaser-body { position: relative; overflow: hidden; max-height: 320px; margin-bottom: 0; }
    .teaser-body p { font-size: 1em; line-height: 1.7; color: var(--color-fg); margin-bottom: 1em; }
    .teaser-fade {
      position: absolute; bottom: 0; left: 0; right: 0; height: 160px;
      background: linear-gradient(to bottom, transparent, var(--color-bg));
    }

    /* Paywall prompt */
    .paywall-prompt {
      text-align: center; padding: 2rem 1.5rem;
      border: 1px solid var(--color-border); border-radius: 12px;
      background: var(--color-card); margin-top: 0;
    }
    .paywall-heading { font-size: 1.15em; font-weight: 700; margin: 0 0 0.4rem; color: var(--color-fg); font-family: 'Merriweather', serif; }
    .paywall-sub { font-size: 0.9em; color: #666; margin: 0 0 1.25rem; }
    .gate-btn {
      display: inline-block; background: var(--color-accent); color: white;
      padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;
      text-decoration: none; font-size: 0.95em;
    }
    .gate-btn:hover { opacity: 0.9; text-decoration: none; }
    .gate-sub { font-size: 0.82em; color: #888; margin: 1rem 0 0; }
    .gate-sub a { color: var(--color-accent); }

    /* Auth gate (fallback) */
    .auth-gate { max-width: 400px; margin: 4rem auto; text-align: center; }
    .gate-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 2.5rem; }
    .gate-card h2 { margin: 0 0 0.5rem; font-size: 1.5em; }
    .gate-card > p { color: #666; font-size: 0.92em; margin: 0 0 1.5rem; }
  </style>

  <script>
    const API = window.API_URL;
    const sid = localStorage.getItem('ae_session');

    const contentTier = document.querySelector('[data-content-tier]')?.dataset.contentTier;

    // Free articles or featured free: show full content immediately, no gating
    const isFeaturedFree = document.querySelector('[data-featured-free]')?.dataset.featuredFree === 'true';
    if (contentTier === 'free' || isFeaturedFree) {
      document.getElementById('article-teaser')?.remove();
      document.getElementById('auth-gate')?.remove();
      document.getElementById('pro-content').style.display = 'block';
    }

    function showTeaser() {
      document.getElementById('article-teaser').style.display = 'block';
      document.getElementById('auth-gate').style.display = 'none';
      document.getElementById('pro-content').style.display = 'none';
    }

    function showContent() {
      document.getElementById('article-teaser').style.display = 'none';
      document.getElementById('auth-gate').style.display = 'none';
      document.getElementById('pro-content').style.display = 'block';
    }

    if (sid) {
      const cachedTier = localStorage.getItem('ae_tier');
      // Quick show for valid cached tier (avoids flash)
      if (cachedTier === 'inner' || (cachedTier === 'pro' && contentTier !== 'founding')) {
        showContent();
      }

      // Verify with server in background
      fetch(`${API}/api/auth/session`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ session_id: sid })
      }).then(r => r.json()).then(data => {
        if (data.success && (data.tier === 'pro' || data.tier === 'inner')) {
          localStorage.setItem('ae_tier', data.tier);
          // Founding content requires inner tier
          if (contentTier === 'founding' && data.tier !== 'inner') {
            showTeaser();
            return;
          }
          showContent();
        } else {
          // Session invalid — show teaser but don't nuke the session
          // (could be a transient API error, not an invalid session)
          showTeaser();
        }
      }).catch(() => {
        // Network error — don't clear session, just show teaser
        showTeaser();
      });
    }
  </script>
</BaseLayout>
