---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="Page not found">
  <div class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <a href="/" class="back-home">Back to Agentic Edge</a>
  </div>

  <style>
    .not-found {
      text-align: center;
      padding: 6rem 0;
    }
    h1 {
      font-size: 4em;
      margin: 0 0 0.5rem;
      color: var(--color-muted);
    }
    p {
      color: var(--color-muted);
      margin: 0 0 2rem;
      font-size: 1.1em;
    }
    .back-home {
      display: inline-block;
      background: var(--color-accent);
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
    }
    .back-home:hover { opacity: 0.9; text-decoration: none; }
  </style>
</BaseLayout>
