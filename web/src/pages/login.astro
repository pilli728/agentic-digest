---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign In" description="Sign in to access your Agentic Edge account">
  <div class="login-page">

    <!-- Login form -->
    <div class="login-card" id="login-card">
      <h1>Sign in</h1>
      <p>Enter your email and we'll send you a magic link. No password needed.</p>
      <form id="login-form">
        <input type="email" placeholder="you@company.com" required id="login-email" />
        <button type="submit" id="login-btn">Send magic link</button>
      </form>
      <p class="login-note">Not a subscriber yet? <a href="/">Join for free</a></p>
    </div>

    <!-- Check email state -->
    <div class="login-card" id="check-email" style="display:none">
      <div class="check-icon">📧</div>
      <h1>Check your email</h1>
      <p>We sent a magic link to <strong id="sent-to-email"></strong></p>
      <p class="check-note">Click the link in your email to sign in. It expires in 15 minutes.</p>
      <button class="try-again" onclick="document.getElementById('check-email').style.display='none'; document.getElementById('login-card').style.display='block';">Try a different email</button>
    </div>

    <!-- Error state -->
    <div class="login-card" id="login-error" style="display:none">
      <h1>Not found</h1>
      <p>No account found for that email. <a href="/">Subscribe first</a>, then come back to sign in.</p>
      <button class="try-again" onclick="document.getElementById('login-error').style.display='none'; document.getElementById('login-card').style.display='block';">Try again</button>
    </div>

  </div>

  <style>
    .login-page { max-width: 420px; margin: 4rem auto; }
    .login-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 2.5rem; text-align: center; }
    h1 { font-size: 1.5em; margin: 0 0 0.5rem; }
    .login-card > p { color: #666; margin: 0 0 1.5rem; font-size: 0.95em; }
    form { display: flex; flex-direction: column; gap: 0.75rem; }
    input { padding: 0.85rem 1rem; border: 2px solid #eee; border-radius: 8px; font-size: 1em; text-align: center; }
    input:focus { outline: none; border-color: #7c3aed; }
    button[type="submit"] { padding: 0.85rem; background: #7c3aed; color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 1em; cursor: pointer; }
    button[type="submit"]:hover { background: #6d28d9; }
    button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }
    .login-note { font-size: 0.85em; color: #999; margin: 1.5rem 0 0; }
    .login-note a { color: #7c3aed; }
    .check-icon { font-size: 3em; margin-bottom: 1rem; }
    .check-note { font-size: 0.85em; color: #999; margin: 1rem 0 0; }
    .try-again { background: none; border: 1px solid #ddd; padding: 0.5rem 1.5rem; border-radius: 6px; color: #666; cursor: pointer; margin-top: 1rem; font-size: 0.9em; }
    .try-again:hover { border-color: #7c3aed; color: #7c3aed; }
  </style>

  <script>
    const API = window.API_URL;

    // Check if already logged in
    const sessionId = localStorage.getItem('ae_session');
    if (sessionId) {
      fetch(`${API}/api/auth/session`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ session_id: sessionId })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          window.location.href = '/pro';
        }
      });
    }

    document.getElementById('login-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('login-email').value;
      const btn = document.getElementById('login-btn');
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const res = await fetch(`${API}/api/auth/login`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ email })
      });
      const data = await res.json();

      if (data.success) {
        document.getElementById('sent-to-email').textContent = email;
        document.getElementById('login-card').style.display = 'none';
        document.getElementById('check-email').style.display = 'block';
      } else {
        document.getElementById('login-card').style.display = 'none';
        document.getElementById('login-error').style.display = 'block';
      }
    });
  </script>
</BaseLayout>
