---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Signing In..." description="Verifying your magic link">
  <div class="verify-page">
    <div class="verify-card" id="verifying">
      <div class="spinner"></div>
      <h1>Signing you in...</h1>
    </div>

    <div class="verify-card" id="verify-success" style="display:none">
      <div class="success-icon">✓</div>
      <h1>You're in!</h1>
      <p>Signed in as <strong id="verified-email"></strong></p>
      <p class="tier-info" id="tier-info"></p>
      <a href="/pro" class="continue-btn">Go to The Vault →</a>
    </div>

    <div class="verify-card" id="verify-fail" style="display:none">
      <h1>Link expired</h1>
      <p>That magic link is no longer valid. They expire after 15 minutes.</p>
      <a href="/login" class="continue-btn secondary">Request a new link</a>
    </div>
  </div>

  <style>
    .verify-page { max-width: 420px; margin: 4rem auto; }
    .verify-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 2.5rem; text-align: center; }
    h1 { font-size: 1.5em; margin: 0 0 0.75rem; }
    p { color: #666; margin: 0 0 0.5rem; }
    .spinner { width: 40px; height: 40px; border: 3px solid #eee; border-top-color: #7c3aed; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1.5rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .success-icon { width: 48px; height: 48px; background: #22c55e; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5em; font-weight: 700; margin: 0 auto 1rem; }
    .tier-info { font-size: 0.9em; color: #7c3aed; font-weight: 500; margin: 0.5rem 0 1.5rem; }
    .continue-btn { display: inline-block; background: #7c3aed; color: white; padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none; font-weight: 600; margin-top: 1rem; }
    .continue-btn:hover { background: #6d28d9; }
    .continue-btn.secondary { background: transparent; border: 1px solid #ddd; color: #333; }
  </style>

  <script>
    const API = window.API_URL;

    async function verify() {
      const params = new URLSearchParams(window.location.search);
      const token = params.get('token');

      // If already logged in and no new token to verify, redirect to /pro
      if (!token) {
        const existingSession = localStorage.getItem('ae_session');
        if (existingSession) {
          try {
            const sessionRes = await fetch(`${API}/api/auth/session`, {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({ session_id: existingSession })
            });
            const sessionData = await sessionRes.json();
            if (sessionData.success) {
              window.location.href = '/pro';
              return;
            }
          } catch (e) {
            // Session check failed, fall through to show error
          }
        }
      }

      if (!token) {
        document.getElementById('verifying').style.display = 'none';
        document.getElementById('verify-fail').style.display = 'block';
        return;
      }

      try {
        const res = await fetch(`${API}/api/auth/verify`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ token })
        });
        const data = await res.json();

        if (data.success) {
          // Store session
          localStorage.setItem('ae_session', data.session_id);
          localStorage.setItem('ae_email', data.email);
          localStorage.setItem('ae_tier', data.tier);

          document.getElementById('verified-email').textContent = data.email;
          const tierLabels = { free: 'Free Plan', pro: 'Pro Member', inner: 'Inner Circle' };
          document.getElementById('tier-info').textContent = tierLabels[data.tier] || data.tier;

          document.getElementById('verifying').style.display = 'none';
          document.getElementById('verify-success').style.display = 'block';
        } else {
          document.getElementById('verifying').style.display = 'none';
          document.getElementById('verify-fail').style.display = 'block';
        }
      } catch (err) {
        document.getElementById('verifying').style.display = 'none';
        document.getElementById('verify-fail').style.display = 'block';
      }
    }

    verify();
  </script>
</BaseLayout>
