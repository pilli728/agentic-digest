---
/**
 * Digest Curation Dashboard
 *
 * Editorial workflow for deciding which stories go in the next digest.
 * Three-column triage: Candidates → Maybe / Accepted
 * Keyboard-driven: j/k navigate, a accept, s skip, m maybe, u undo
 */
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📡</text></svg>" />
    <title>Curate Digest | Agentic Edge</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style is:inline>
      :root {
        --bg: #0f0f0f;
        --fg: #e5e5e5;
        --fg-muted: #888;
        --fg-dim: #555;
        --border: #2a2a2a;
        --border-hover: #444;
        --accent: #60a5fa;
        --accent-dim: rgba(96, 165, 250, 0.15);
        --green: #34d399;
        --green-dim: rgba(52, 211, 153, 0.12);
        --green-border: rgba(52, 211, 153, 0.3);
        --amber: #fbbf24;
        --amber-dim: rgba(251, 191, 36, 0.12);
        --amber-border: rgba(251, 191, 36, 0.3);
        --red: #f87171;
        --red-dim: rgba(248, 113, 113, 0.08);
        --red-border: rgba(248, 113, 113, 0.2);
        --surface: #161616;
        --surface-raised: #1c1c1c;
        --radius: 8px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
        overflow-x: hidden;
      }

      /* ── Top bar ── */
      .topbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(15, 15, 15, 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .topbar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .topbar-left a {
        color: var(--fg-muted);
        text-decoration: none;
        font-size: 0.85em;
      }

      .topbar h1 {
        font-size: 1.1em;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .topbar-date {
        font-size: 0.85em;
        color: var(--fg-muted);
      }

      .topbar-actions {
        display: flex;
        gap: 0.5rem;
      }

      .btn {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.85em;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--fg);
        transition: all 0.15s;
        font-family: inherit;
        white-space: nowrap;
      }

      .btn:hover { border-color: var(--border-hover); background: var(--surface-raised); }
      .btn:disabled { opacity: 0.4; cursor: not-allowed; }

      .btn-accent {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .btn-accent:hover { opacity: 0.9; }

      .btn-green {
        background: var(--green);
        color: #000;
        border-color: var(--green);
        font-weight: 600;
      }
      .btn-green:hover { opacity: 0.9; }

      /* ── Stats bar ── */
      .stats-bar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.6rem 1.5rem;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        font-size: 0.8em;
        color: var(--fg-muted);
        flex-wrap: wrap;
      }

      .stat {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      .stat-count {
        font-weight: 600;
        color: var(--fg);
        font-size: 1.1em;
      }

      .stat-accepted .stat-count { color: var(--green); }
      .stat-maybe .stat-count { color: var(--amber); }
      .stat-skipped .stat-count { color: var(--red); }

      .stat-divider {
        width: 1px;
        height: 16px;
        background: var(--border);
      }

      .keyboard-hints {
        margin-left: auto;
        display: flex;
        gap: 0.75rem;
        font-size: 0.8em;
      }

      .keyboard-hints span { color: var(--fg-dim); }

      kbd {
        display: inline-block;
        padding: 0.1em 0.4em;
        border: 1px solid var(--border);
        border-radius: 3px;
        font-family: inherit;
        font-size: 0.9em;
        color: var(--fg);
        background: var(--surface-raised);
        margin-right: 0.2em;
      }

      /* ── Main layout ── */
      .columns {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 0;
        height: calc(100vh - 100px);
        overflow: hidden;
      }

      .column {
        display: flex;
        flex-direction: column;
        border-right: 1px solid var(--border);
        overflow: hidden;
      }

      .column:last-child { border-right: none; }

      .column-header {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: 0.8em;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg-muted);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
        background: var(--surface);
      }

      .column-header .count {
        background: var(--border);
        color: var(--fg);
        padding: 0.1em 0.5em;
        border-radius: 10px;
        font-size: 0.9em;
        font-weight: 600;
      }

      .col-candidates .column-header { border-left: 3px solid var(--accent); }
      .col-maybe .column-header { border-left: 3px solid var(--amber); }
      .col-accepted .column-header { border-left: 3px solid var(--green); }

      .column-body {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem;
      }

      /* Scrollbar styling */
      .column-body::-webkit-scrollbar { width: 4px; }
      .column-body::-webkit-scrollbar-track { background: transparent; }
      .column-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

      /* ── Story cards ── */
      .card {
        padding: 0;
        border: 1px solid var(--border);
        border-radius: 12px;
        margin-bottom: 0.75rem;
        cursor: pointer;
        transition: all 0.18s ease;
        background: var(--surface);
        position: relative;
        overflow: hidden;
      }

      .card:hover {
        border-color: var(--border-hover);
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      }

      .card.focused {
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.3), 0 8px 25px rgba(96, 165, 250, 0.1);
        transform: translateY(-1px);
      }

      .card.state-accepted {
        border-color: var(--green-border);
        background: linear-gradient(135deg, var(--green-dim) 0%, var(--surface) 100%);
      }

      .card.state-maybe {
        border-color: var(--amber-border);
        background: linear-gradient(135deg, var(--amber-dim) 0%, var(--surface) 100%);
      }

      .card.state-skipped {
        border-color: var(--red-border);
        background: var(--red-dim);
        opacity: 0.5;
      }
      .card.state-skipped:hover { opacity: 0.7; }

      /* Score accent strip along the top */
      .card-score-strip {
        height: 3px;
        width: 100%;
        background: var(--border);
      }
      .card-score-strip.high { background: linear-gradient(90deg, var(--green), #6ee7b7); }
      .card-score-strip.medium { background: linear-gradient(90deg, var(--amber), #fde68a); }
      .card-score-strip.low { background: linear-gradient(90deg, var(--red), #fca5a5); }

      .card-body {
        padding: 0.85rem 1rem 0.65rem;
      }

      .card-title {
        font-size: 0.95em;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 0.5rem;
        color: #fff;
        letter-spacing: -0.01em;
      }

      .card-title a {
        color: inherit;
        text-decoration: none;
        transition: color 0.12s;
      }
      .card-title a:hover { color: var(--accent); }

      .card-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.6rem;
        flex-wrap: wrap;
      }

      .score {
        font-size: 0.7em;
        font-weight: 800;
        padding: 0.2em 0.55em;
        border-radius: 6px;
        letter-spacing: 0.02em;
      }

      .score.high {
        background: var(--green);
        color: #000;
      }
      .score.medium {
        background: var(--amber);
        color: #000;
      }
      .score.low {
        background: rgba(248, 113, 113, 0.25);
        color: var(--red);
      }

      .card-source {
        font-size: 0.72em;
        color: var(--fg-muted);
        font-weight: 500;
      }

      .tier-badge {
        font-size: 0.65em;
        color: var(--fg-dim);
        padding: 0.2em 0.5em;
        border: 1px solid var(--border);
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
      }

      .card-summary {
        font-size: 0.82em;
        color: var(--fg-muted);
        line-height: 1.55;
        padding: 0.6rem 0.75rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.04);
        max-height: 4.8em;
        overflow-y: auto;
        cursor: text;
      }

      .card-summary.expanded {
        max-height: none;
      }

      .card-summary::-webkit-scrollbar { width: 3px; }
      .card-summary::-webkit-scrollbar-track { background: transparent; }
      .card-summary::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

      /* Editor note on accepted cards */
      .editor-note {
        margin-top: 0.6rem;
      }

      .editor-note.collapsed .note-input {
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--border);
        min-height: unset;
        height: 2em;
        opacity: 0.5;
        transition: all 0.15s;
      }

      .editor-note.collapsed .note-input:focus,
      .editor-note.collapsed .note-input:not(:placeholder-shown) {
        opacity: 1;
        height: auto;
        min-height: 2.5em;
        border-color: var(--accent);
        background: rgba(96, 165, 250, 0.06);
      }

      .note-input {
        width: 100%;
        padding: 0.6rem 0.75rem;
        background: rgba(52, 211, 153, 0.06);
        border: 1px solid var(--green-border);
        border-radius: 8px;
        color: var(--fg);
        font-family: inherit;
        font-size: 0.82em;
        line-height: 1.5;
        resize: vertical;
        min-height: 2.5em;
        transition: border-color 0.15s;
      }

      .note-input::placeholder {
        color: var(--fg-dim);
        font-style: italic;
      }

      .note-input:focus {
        outline: none;
        border-color: var(--green);
        background: rgba(52, 211, 153, 0.1);
      }

      /* ── Topic picker dropdown ── */
      .picker-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 199;
      }

      .picker-menu {
        position: fixed;
        z-index: 200;
        background: var(--surface-raised);
        border: 1px solid var(--border-hover);
        border-radius: 10px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        max-height: 280px;
        display: flex;
        flex-direction: column;
      }

      .picker-header {
        padding: 0.6rem 0.85rem;
        font-size: 0.75em;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg-muted);
        border-bottom: 1px solid var(--border);
      }

      .picker-options {
        overflow-y: auto;
        max-height: 220px;
      }

      .picker-option {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.55rem 0.85rem;
        background: none;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: var(--fg);
        font-size: 0.85em;
        font-family: inherit;
        cursor: pointer;
        text-align: left;
        transition: background 0.1s;
      }
      .picker-option:hover { background: rgba(255,255,255,0.06); }
      .picker-option:last-child { border-bottom: none; }

      .picker-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        flex-shrink: 0;
      }

      .picker-count {
        margin-left: auto;
        font-size: 0.8em;
        color: var(--fg-dim);
      }

      .picker-new {
        color: var(--accent);
        font-weight: 600;
      }
      .picker-new:hover { background: var(--accent-dim); }

      .picker-divider {
        height: 1px;
        background: var(--border);
      }

      /* Column header button */
      .col-header-btn {
        margin-left: auto;
        padding: 0.2em 0.6em;
        border-radius: 4px;
        font-size: 0.9em;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid var(--green-border);
        background: var(--green-dim);
        color: var(--green);
        font-family: inherit;
      }
      .col-header-btn:hover { background: rgba(52, 211, 153, 0.25); }

      /* ── Topic bubbles ── */
      .topic-bubble {
        border: 1px solid var(--green-border);
        border-radius: 12px;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, var(--green-dim) 0%, var(--surface) 100%);
        overflow: hidden;
      }

      .topic-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0.85rem;
        border-bottom: 1px solid rgba(52, 211, 153, 0.15);
      }

      .topic-title-input {
        flex: 1;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 0.9em;
        font-weight: 700;
        font-family: inherit;
        padding: 0.2em 0;
        outline: none;
        border-bottom: 1px solid transparent;
      }
      .topic-title-input:focus {
        border-bottom-color: var(--green);
      }
      .topic-title-input::placeholder { color: var(--fg-dim); }

      .topic-article-count {
        font-size: 0.7em;
        color: var(--fg-muted);
        background: var(--border);
        padding: 0.15em 0.45em;
        border-radius: 8px;
        flex-shrink: 0;
      }

      .topic-delete {
        background: none;
        border: none;
        color: var(--fg-dim);
        cursor: pointer;
        font-size: 0.85em;
        padding: 0.2em;
        border-radius: 4px;
        flex-shrink: 0;
      }
      .topic-delete:hover { color: var(--red); background: var(--red-dim); }

      .topic-articles {
        padding: 0.4rem 0.6rem;
      }

      /* Drag and drop states */
      .topic-bubble.drop-target {
        border-style: dashed;
      }
      .topic-bubble.drag-over {
        border-color: var(--green);
        background: rgba(52, 211, 153, 0.08);
        box-shadow: 0 0 0 2px rgba(52, 211, 153, 0.2);
      }

      .drag-handle {
        cursor: grab;
        color: var(--fg-dim);
        font-size: 0.9em;
        flex-shrink: 0;
        user-select: none;
        opacity: 0.4;
        transition: opacity 0.1s;
        line-height: 1;
      }
      .topic-article-item:hover .drag-handle,
      .card:hover .drag-handle { opacity: 1; }

      .topic-article-item {
        display: flex;
        align-items: start;
        gap: 0.4rem;
        padding: 0.35rem 0.3rem;
        border-radius: 6px;
        font-size: 0.78em;
        transition: background 0.1s;
        cursor: grab;
      }
      .topic-article-item:hover { background: rgba(255,255,255,0.04); }
      .topic-article-item:active { cursor: grabbing; }

      .topic-article-item a {
        color: var(--fg);
        text-decoration: none;
        line-height: 1.35;
        flex: 1;
      }
      .topic-article-item a:hover { color: var(--accent); }

      .topic-article-source {
        color: var(--fg-dim);
        font-size: 0.85em;
        flex-shrink: 0;
      }

      .topic-article-remove {
        background: none;
        border: none;
        color: var(--fg-dim);
        cursor: pointer;
        font-size: 0.75em;
        padding: 0.1em 0.3em;
        border-radius: 3px;
        flex-shrink: 0;
        opacity: 0;
        transition: opacity 0.1s;
      }
      .topic-article-item:hover .topic-article-remove { opacity: 1; }
      .topic-article-remove:hover { color: var(--red); background: var(--red-dim); }

      .topic-synthesis {
        padding: 0 0.6rem 0.6rem;
      }

      .topic-synthesis textarea {
        width: 100%;
        padding: 0.55rem 0.7rem;
        background: rgba(52, 211, 153, 0.06);
        border: 1px solid rgba(52, 211, 153, 0.2);
        border-radius: 8px;
        color: var(--fg);
        font-family: inherit;
        font-size: 0.82em;
        line-height: 1.55;
        resize: vertical;
        min-height: 3em;
      }
      .topic-synthesis textarea::placeholder { color: var(--fg-dim); font-style: italic; }
      .topic-synthesis textarea:focus { outline: none; border-color: var(--green); background: rgba(52, 211, 153, 0.1); }

      /* Ungrouped accepted articles */
      .ungrouped-label {
        font-size: 0.72em;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg-dim);
        padding: 0.75rem 0.5rem 0.25rem;
      }

      .card-actions {
        display: flex;
        gap: 0;
        border-top: 1px solid var(--border);
      }

      .card-btn {
        flex: 1;
        padding: 0.55rem 0.5rem;
        font-size: 0.72em;
        font-weight: 700;
        cursor: pointer;
        border: none;
        border-right: 1px solid var(--border);
        background: transparent;
        color: var(--fg-dim);
        transition: all 0.12s;
        font-family: inherit;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .card-btn:last-child { border-right: none; }

      .card-btn:hover { color: var(--fg); background: rgba(255, 255, 255, 0.04); }

      .card-btn.btn-accept:hover {
        color: var(--green);
        background: var(--green-dim);
      }
      .card-btn.btn-maybe:hover {
        color: var(--amber);
        background: var(--amber-dim);
      }
      .card-btn.btn-skip:hover {
        color: var(--red);
        background: var(--red-dim);
      }
      .card-btn.btn-undo:hover {
        color: var(--accent);
        background: var(--accent-dim);
      }

      .card-rank {
        position: absolute;
        top: 8px;
        right: 10px;
        font-size: 1.3em;
        font-weight: 800;
        color: var(--green);
        opacity: 0.18;
        z-index: 1;
        line-height: 1;
      }

      /* ── Preview overlay ── */
      .preview-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        z-index: 200;
        display: none;
        align-items: center;
        justify-content: center;
      }

      .preview-overlay.visible { display: flex; }

      .preview-panel {
        background: #ffffff;
        color: #1a1a1a;
        border: none;
        border-radius: 0;
        width: 100%;
        max-width: 640px;
        max-height: 90vh;
        overflow-y: auto;
        padding: 3rem 2.5rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
        font-family: 'Inter', system-ui, sans-serif;
      }

      .preview-masthead {
        text-align: center;
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
        border-bottom: 2px solid #111;
      }

      .preview-masthead h2 {
        font-size: 1.8em;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.02em;
        color: #111;
      }

      .preview-masthead .preview-date {
        font-size: 0.85em;
        color: #888;
        margin-top: 0.3rem;
      }

      .preview-body {
        font-size: 0.95em;
        line-height: 1.75;
        color: #333;
      }

      .preview-body h2 {
        font-size: 1.15em;
        font-weight: 700;
        color: #111;
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid #eee;
      }

      .preview-body h2:first-child { margin-top: 0; }

      .preview-body p {
        margin: 0 0 1rem;
      }

      .preview-body strong {
        color: #111;
      }

      .preview-body a {
        color: #7c3aed;
        text-decoration: none;
        font-weight: 500;
      }
      .preview-body a:hover { text-decoration: underline; }

      .preview-body hr {
        border: none;
        border-top: 1px solid #eee;
        margin: 1.5rem 0;
      }

      .preview-footer {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 2px solid #111;
        text-align: center;
        font-size: 0.8em;
        color: #999;
      }

      .preview-body[contenteditable="true"]:focus {
        outline: none;
        box-shadow: inset 0 0 0 2px rgba(124, 58, 237, 0.2);
        border-radius: 4px;
      }

      .preview-feedback {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #f8f8f8;
        border-radius: 8px;
        border: 1px solid #eee;
      }

      .preview-feedback textarea {
        width: 100%;
        padding: 0.6rem 0.75rem;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-family: inherit;
        font-size: 0.85em;
        line-height: 1.5;
        resize: vertical;
        min-height: 2.5em;
        color: #333;
        margin-bottom: 0.5rem;
      }
      .preview-feedback textarea:focus { outline: none; border-color: #7c3aed; }
      .preview-feedback textarea::placeholder { color: #aaa; }

      .preview-feedback .btn {
        background: #7c3aed;
        color: #fff;
        border-color: #7c3aed;
        font-size: 0.82em;
      }
      .preview-feedback .btn:hover { background: #6d28d9; }

      .preview-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        margin-top: 1.5rem;
      }

      .preview-actions .btn {
        background: #fff;
        color: #333;
        border: 1px solid #ddd;
      }
      .preview-actions .btn:hover { border-color: #7c3aed; color: #7c3aed; }
      .preview-actions .btn-green { background: #7c3aed; color: #fff; border-color: #7c3aed; }

      /* ── Loading & empty states ── */
      .loading {
        text-align: center;
        padding: 3rem;
        color: var(--fg-muted);
      }

      .loading-spinner {
        width: 24px;
        height: 24px;
        border: 2px solid var(--border);
        border-top: 2px solid var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 1rem;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      .empty-col {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--fg-dim);
        font-size: 0.85em;
      }

      /* ── Toast notifications ── */
      .toast {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 300;
        padding: 0.75rem 1.25rem;
        background: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 0.85em;
        color: var(--fg);
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.2s;
        pointer-events: none;
      }

      .toast.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* ── Responsive ── */
      @media (max-width: 1024px) {
        .columns {
          grid-template-columns: 1fr;
          height: auto;
        }

        .column {
          border-right: none;
          border-bottom: 1px solid var(--border);
          max-height: 50vh;
        }

        .keyboard-hints { display: none; }
      }

      /* ── Fetch status indicator ── */
      .fetch-status {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8em;
        color: var(--fg-muted);
        margin-left: 0.5rem;
      }

      .fetch-status .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        animation: pulse 1.5s ease infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }

      /* ── Digest goal progress bar ── */
      .digest-goal {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 1.5rem;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        font-size: 0.78em;
        color: var(--fg-muted);
      }

      .goal-bar {
        flex: 1;
        max-width: 200px;
        height: 6px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
      }

      .goal-fill {
        height: 100%;
        background: var(--green);
        border-radius: 3px;
        transition: width 0.3s;
      }

      .goal-fill.over { background: var(--amber); }
    </style>
  </head>

  <body>
    <!-- Top bar -->
    <div class="topbar">
      <div class="topbar-left">
        <a href="/">&larr; Home</a>
        <h1>Curate Digest</h1>
        <span class="topbar-date" id="topbar-date"></span>
        <span class="fetch-status" id="fetch-status" style="display:none">
          <span class="dot"></span>
          <span id="fetch-status-text">Fetching...</span>
        </span>
      </div>
      <div class="topbar-actions">
        <button class="btn" id="btn-fetch" title="Pull fresh stories from sources">Fetch Stories</button>
        <button class="btn" id="btn-preview" title="Preview rendered digest (Esc to close)">Preview</button>
        <button class="btn btn-green" id="btn-publish" title="Publish digest to email + website">Publish</button>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="stat stat-candidates">
        <span class="stat-count" id="count-candidates">0</span> candidates
      </div>
      <div class="stat-divider"></div>
      <div class="stat stat-accepted">
        <span class="stat-count" id="count-accepted">0</span> accepted
      </div>
      <div class="stat-divider"></div>
      <div class="stat stat-maybe">
        <span class="stat-count" id="count-maybe">0</span> maybe
      </div>
      <div class="stat-divider"></div>
      <div class="stat stat-skipped">
        <span class="stat-count" id="count-skipped">0</span> skipped
      </div>
      <div class="keyboard-hints">
        <span><kbd>j</kbd><kbd>k</kbd> navigate</span>
        <span><kbd>a</kbd> accept</span>
        <span><kbd>m</kbd> maybe</span>
        <span><kbd>s</kbd> skip</span>
        <span><kbd>u</kbd> undo</span>
        <span><kbd>e</kbd> expand</span>
      </div>
    </div>

    <!-- Digest goal progress -->
    <div class="digest-goal">
      <span>Digest goal:</span>
      <div class="goal-bar">
        <div class="goal-fill" id="goal-fill" style="width: 0%"></div>
      </div>
      <span id="goal-text">0 / 15 stories</span>
    </div>

    <!-- Three columns -->
    <div class="columns">
      <div class="column col-candidates">
        <div class="column-header">
          Candidates <span class="count" id="col-count-candidates">0</span>
        </div>
        <div class="column-body" id="col-candidates"></div>
      </div>

      <div class="column col-maybe">
        <div class="column-header">
          Maybe <span class="count" id="col-count-maybe">0</span>
        </div>
        <div class="column-body" id="col-maybe"></div>
      </div>

      <div class="column col-accepted">
        <div class="column-header">
          Digest Topics <span class="count" id="col-count-accepted">0</span>
          <button class="col-header-btn" id="btn-new-topic" title="Create a topic from scratch">+ Topic</button>
        </div>
        <div class="column-body" id="col-accepted"></div>
      </div>
    </div>

    <!-- Preview overlay -->
    <div class="preview-overlay" id="preview-overlay">
      <div class="preview-panel">
        <div class="preview-masthead">
          <h2>Agentic Edge</h2>
          <div class="preview-date" id="preview-date"></div>
        </div>
        <div class="preview-body" id="preview-content" contenteditable="true">Loading...</div>
        <div class="preview-feedback">
          <textarea id="preview-feedback-input" placeholder="Feedback: 'make the tools section punchier' or 'rewrite distribution to focus more on...'"></textarea>
          <button class="btn" id="btn-regenerate">Regenerate with feedback</button>
        </div>
        <div class="preview-footer">
          You're reading Agentic Edge — the weekly brief for AI agent builders.<br>
          Curated from 700+ sources. Zero AI slop.
        </div>
        <div class="preview-actions">
          <button class="btn" id="btn-close-preview">Close (Esc)</button>
          <button class="btn btn-green" id="btn-publish-from-preview">Publish this digest</button>
        </div>
      </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script>
      const API = 'http://localhost:8000';
      const DIGEST_GOAL = 15;

      // ── State ──
      let articles = [];
      let topics = [];
      let focusedId = null;
      let focusedColumn = 'candidates';

      // ── DOM refs ──
      const colCandidates = document.getElementById('col-candidates');
      const colMaybe = document.getElementById('col-maybe');
      const colAccepted = document.getElementById('col-accepted');
      const previewOverlay = document.getElementById('preview-overlay');
      const toast = document.getElementById('toast');

      // ── Init ──
      setDate();
      loadArticles();

      function setDate() {
        const d = new Date();
        document.getElementById('topbar-date').textContent = d.toLocaleDateString('en-US', {
          weekday: 'short', month: 'short', day: 'numeric'
        });
      }

      // ── Summary cleaning ──
      function cleanSummary(rssSummary, whyItMatters) {
        // Strip HTML tags from RSS summary
        const stripHtml = (s) => {
          const div = document.createElement('div');
          div.innerHTML = s;
          return div.textContent || div.innerText || '';
        };

        const raw = rssSummary || '';
        const cleaned = stripHtml(raw).trim();

        // Skip useless summaries: HN/Reddit point counts, empty, too short
        const isUseless = !cleaned
          || cleaned.length < 30
          || /^Points:\s*\d+/i.test(cleaned)
          || /^Comments:\s*\d+/i.test(cleaned)
          || /Trending on (Hacker News|Reddit)/i.test(cleaned);

        if (!isUseless) return cleaned;

        // Fall back to why_it_matters only if it's not the keyword-match garbage
        const wim = (whyItMatters || '').trim();
        if (wim && !wim.startsWith('High signal') && !wim.startsWith('Actionable')
            && !wim.startsWith('Worth a look') && !wim.startsWith('Paradigm shift')
            && !wim.startsWith('Low signal') && !wim.startsWith('Filtered')
            && !wim.startsWith('Research') && !wim.startsWith('Auto-skipped')) {
          return wim;
        }

        return '';
      }

      // ── Data loading ──
      async function loadArticles() {
        showLoadingIn(colCandidates);
        showLoadingIn(colMaybe);
        showLoadingIn(colAccepted);

        try {
          const res = await fetch(`${API}/api/curate/state`);
          const data = await res.json();

          if (data.success) {
            articles = data.articles.map(a => ({
              id: a.id,
              title: a.title,
              source: a.source,
              tier: a.tier,
              score: a.relevance_score || 0,
              summary: cleanSummary(a.summary, a.why_it_matters),
              link: a.link,
              state: a.curation_state || 'candidate',
              acceptOrder: a.accept_order || 999999,
              editorNote: a.editor_note || '',
              topicId: null,
            }));

            // Load topics
            try {
              const topicsRes = await fetch(`${API}/api/topics`);
              const topicsData = await topicsRes.json();
              if (topicsData.success) {
                topics = topicsData.topics.map(t => ({
                  id: t.id,
                  title: t.title,
                  synthesis: t.synthesis || '',
                  articleIds: t.articles.map(a => a.id),
                }));
                // Mark articles that belong to topics
                for (const t of topics) {
                  for (const aid of t.articleIds) {
                    const a = articles.find(x => x.id === aid);
                    if (a) {
                      a.topicId = t.id;
                      a.state = 'accepted';
                    }
                  }
                }
              }
            } catch (e) { /* topics not loaded, that's ok */ }

            render();
            if (getCandidates().length > 0) {
              focusedId = getCandidates()[0].id;
              focusedColumn = 'candidates';
              updateFocusUI();
            }
          }
        } catch (err) {
          showLoadingIn(colCandidates, 'Could not connect to API. Start it with: python3 src/api_server.py');
          colMaybe.innerHTML = '';
          colAccepted.innerHTML = '';
        }
      }

      function showLoadingIn(el, msg) {
        if (msg) {
          el.innerHTML = `<div class="empty-col">${msg}</div>`;
        } else {
          el.innerHTML = '<div class="loading"><div class="loading-spinner"></div>Loading...</div>';
        }
      }

      // ── Getters ──
      function getCandidates() {
        return articles.filter(a => a.state === 'candidate').sort((a, b) => b.score - a.score);
      }
      function getMaybes() {
        return articles.filter(a => a.state === 'maybe').sort((a, b) => b.score - a.score);
      }
      function getAccepted() {
        return articles.filter(a => a.state === 'accepted').sort((a, b) => a.acceptOrder - b.acceptOrder);
      }
      function getSkipped() {
        return articles.filter(a => a.state === 'skipped');
      }

      // ── Render ──
      function render() {
        renderColumn(colCandidates, getCandidates(), 'candidate');
        renderColumn(colMaybe, getMaybes(), 'maybe');
        renderTopicsColumn();
        updateCounts();
        updateFocusUI();
      }

      function renderColumn(el, items, type) {
        if (items.length === 0) {
          const messages = {
            candidate: 'No stories to review. Hit "Fetch Stories" to pull new ones.',
            maybe: 'Stories you\'re on the fence about will appear here.',
            accepted: 'Accept stories to build your digest.',
          };
          el.innerHTML = `<div class="empty-col">${messages[type]}</div>`;
          return;
        }

        el.innerHTML = items.map((a, i) => cardHTML(a, type, i)).join('');

        // Attach event listeners
        el.querySelectorAll('.card').forEach(card => {
          const id = card.dataset.id;
          card.addEventListener('click', (e) => {
            if (e.target.closest('.card-btn') || e.target.closest('.card-title a')) return;
            focusedId = id;
            focusedColumn = type === 'candidate' ? 'candidates' : type;
            updateFocusUI();
          });
        });

        el.querySelectorAll('.card-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const id = btn.closest('.card').dataset.id;
            const action = btn.dataset.action;
            handleAction(id, action);
          });
        });

        // Editor note auto-save (debounced)
        el.querySelectorAll('.note-input').forEach(textarea => {
          // Don't capture keyboard shortcuts while typing
          textarea.addEventListener('keydown', (e) => e.stopPropagation());
          textarea.addEventListener('click', (e) => e.stopPropagation());

          let saveTimeout;
          textarea.addEventListener('input', () => {
            const id = textarea.dataset.id;
            const note = textarea.value;
            // Update in-memory
            const article = articles.find(a => a.id === id);
            if (article) article.editorNote = note;
            // Debounced save
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => saveEditorNote(id, note), 800);
          });
        });
      }

      // ── Topics column ──
      function renderTopicsColumn() {
        const accepted = getAccepted();
        const ungrouped = accepted.filter(a => !a.topicId);

        if (topics.length === 0 && ungrouped.length === 0) {
          colAccepted.innerHTML = '<div class="empty-col">Accept stories and group them into topics for your digest.</div>';
          return;
        }

        let html = '';

        // Render each topic bubble
        for (const topic of topics) {
          const topicArticles = topic.articleIds
            .map(id => articles.find(a => a.id === id))
            .filter(Boolean);

          html += `
            <div class="topic-bubble" data-topic-id="${topic.id}"
              ondragover="event.preventDefault(); this.classList.add('drag-over')"
              ondragleave="this.classList.remove('drag-over')"
              ondrop="handleTopicDrop(event, '${topic.id}')">
              <div class="topic-header">
                <input class="topic-title-input" value="${escapeHtml(topic.title)}"
                  placeholder="Topic name..." data-topic-id="${topic.id}" />
                <span class="topic-article-count">${topicArticles.length} source${topicArticles.length !== 1 ? 's' : ''}</span>
                <button class="topic-delete" data-topic-id="${topic.id}" title="Delete topic">&times;</button>
              </div>
              <div class="topic-articles">
                ${topicArticles.map(a => `
                  <div class="topic-article-item" draggable="true"
                    data-article-id="${a.id}" data-from-topic="${topic.id}"
                    ondragstart="handleArticleDragStart(event, '${a.id}', '${topic.id}')">
                    <span class="drag-handle">⠿</span>
                    <a href="${a.link}" target="_blank">${escapeHtml(a.title)}</a>
                    <span class="topic-article-source">${escapeHtml(a.source)}</span>
                    <button class="topic-article-remove" data-topic-id="${topic.id}" data-article-id="${a.id}">&times;</button>
                  </div>
                `).join('')}
              </div>
              <div class="topic-synthesis">
                <textarea placeholder="Your synthesis — combine these sources into your take..."
                  data-topic-id="${topic.id}" rows="3">${escapeHtml(topic.synthesis)}</textarea>
              </div>
            </div>
          `;
        }

        // Ungrouped accepted articles — draggable into topics
        if (ungrouped.length > 0) {
          html += '<div class="ungrouped-label">Ungrouped — drag into a topic above</div>';
          html += ungrouped.map((a, i) => `
            <div class="card state-accepted" data-id="${a.id}" draggable="true"
              ondragstart="handleArticleDragStart(event, '${a.id}', '')">
              <div class="card-score-strip ${a.score >= 8 ? 'high' : a.score >= 5 ? 'medium' : 'low'}"></div>
              <div class="card-body">
                <div class="card-title">
                  <span class="drag-handle">⠿</span>
                  <a href="${a.link}" target="_blank" rel="noopener">${escapeHtml(a.title)}</a>
                </div>
                <div class="card-meta">
                  <span class="card-source">${escapeHtml(a.source)}</span>
                </div>
              </div>
              <div class="card-actions">
                <button class="card-btn btn-undo" data-action="undo">Remove</button>
              </div>
            </div>
          `).join('');
        }

        colAccepted.innerHTML = html;

        // Attach topic event listeners
        colAccepted.querySelectorAll('.topic-title-input').forEach(input => {
          input.addEventListener('keydown', e => e.stopPropagation());
          let saveT;
          input.addEventListener('input', () => {
            const tid = input.dataset.topicId;
            const t = topics.find(x => x.id === tid);
            if (t) t.title = input.value;
            clearTimeout(saveT);
            saveT = setTimeout(() => apiTopicUpdate(tid, { title: input.value }), 800);
          });
        });

        colAccepted.querySelectorAll('.topic-synthesis textarea').forEach(ta => {
          ta.addEventListener('keydown', e => e.stopPropagation());
          ta.addEventListener('click', e => e.stopPropagation());
          let saveT;
          ta.addEventListener('input', () => {
            const tid = ta.dataset.topicId;
            const t = topics.find(x => x.id === tid);
            if (t) t.synthesis = ta.value;
            clearTimeout(saveT);
            saveT = setTimeout(() => apiTopicUpdate(tid, { synthesis: ta.value }), 800);
          });
        });

        colAccepted.querySelectorAll('.topic-delete').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            deleteTopic(btn.dataset.topicId);
          });
        });

        colAccepted.querySelectorAll('.topic-article-remove').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            removeArticleFromTopic(btn.dataset.topicId, btn.dataset.articleId);
          });
        });

        // Ungrouped card listeners
        colAccepted.querySelectorAll('.card').forEach(card => {
          const id = card.dataset.id;
          card.addEventListener('click', (e) => {
            if (e.target.closest('.card-btn') || e.target.closest('.card-title a') || e.target.closest('.note-input')) return;
            focusedId = id;
            focusedColumn = 'accepted';
            updateFocusUI();
          });
        });
        colAccepted.querySelectorAll('.card-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleAction(btn.closest('.card').dataset.id, btn.dataset.action);
          });
        });
        colAccepted.querySelectorAll('.card .note-input').forEach(textarea => {
          textarea.addEventListener('keydown', e => e.stopPropagation());
          textarea.addEventListener('click', e => e.stopPropagation());
          let saveT;
          textarea.addEventListener('input', () => {
            const id = textarea.dataset.id;
            const article = articles.find(a => a.id === id);
            if (article) article.editorNote = textarea.value;
            clearTimeout(saveT);
            saveT = setTimeout(() => saveEditorNote(id, textarea.value), 800);
          });
        });
      }

      // ── Topic API helpers ──
      async function apiTopicUpdate(id, fields) {
        try {
          await fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'update', id, ...fields }),
          });
        } catch (e) { console.warn('Topic update failed:', e); }
      }

      async function createTopic(title, articleIds = []) {
        const id = 't_' + Date.now().toString(36);
        topics.push({ id, title, synthesis: '', articleIds });
        for (const aid of articleIds) {
          const a = articles.find(x => x.id === aid);
          if (a) a.topicId = id;
        }
        render();
        try {
          await fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'create', id, title, article_ids: articleIds }),
          });
        } catch (e) { console.warn('Topic create failed:', e); }
      }

      async function deleteTopic(topicId) {
        const t = topics.find(x => x.id === topicId);
        if (!t) return;
        // Unassign articles
        for (const aid of t.articleIds) {
          const a = articles.find(x => x.id === aid);
          if (a) { a.topicId = null; a.state = 'candidate'; }
        }
        topics = topics.filter(x => x.id !== topicId);
        render();
        try {
          await fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'delete', id: topicId }),
          });
        } catch (e) { console.warn('Topic delete failed:', e); }
      }

      async function removeArticleFromTopic(topicId, articleId) {
        const t = topics.find(x => x.id === topicId);
        if (t) t.articleIds = t.articleIds.filter(id => id !== articleId);
        const a = articles.find(x => x.id === articleId);
        if (a) { a.topicId = null; a.state = 'candidate'; }
        render();
        try {
          await fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'remove_article', id: topicId, article_id: articleId }),
          });
        } catch (e) { console.warn('Remove article failed:', e); }
      }

      // ── Topic picker dropdown ──
      function showTopicPicker(article) {
        // Remove any existing picker
        document.getElementById('topic-picker')?.remove();

        const card = document.querySelector(`.card[data-id="${article.id}"]`);
        if (!card) return;

        const rect = card.getBoundingClientRect();

        let optionsHTML = topics.map(t =>
          `<button class="picker-option" data-topic-id="${t.id}">
            <span class="picker-dot"></span>
            ${escapeHtml(t.title || 'Untitled')}
            <span class="picker-count">${t.articleIds.length}</span>
          </button>`
        ).join('');

        optionsHTML += `
          <div class="picker-divider"></div>
          <button class="picker-option picker-new" data-topic-id="__new__">
            + Create new topic
          </button>
        `;

        const picker = document.createElement('div');
        picker.id = 'topic-picker';
        picker.innerHTML = `
          <div class="picker-backdrop"></div>
          <div class="picker-menu" style="top:${Math.min(rect.bottom + 4, window.innerHeight - 300)}px; left:${rect.left}px; width:${Math.min(rect.width, 320)}px;">
            <div class="picker-header">Add to topic:</div>
            <div class="picker-options">${optionsHTML}</div>
          </div>
        `;
        document.body.appendChild(picker);

        // Handle selection
        picker.querySelectorAll('.picker-option').forEach(btn => {
          btn.addEventListener('click', () => {
            const topicId = btn.dataset.topicId;
            picker.remove();
            acceptArticleToTopic(article, topicId);
          });
        });

        // Close on backdrop click or Escape
        picker.querySelector('.picker-backdrop').addEventListener('click', () => picker.remove());
        const escHandler = (e) => {
          if (e.key === 'Escape') { picker.remove(); document.removeEventListener('keydown', escHandler); }
        };
        document.addEventListener('keydown', escHandler);
      }

      async function acceptArticleToTopic(article, topicId) {
        const prevState = article.state;
        article.state = 'accepted';
        article.acceptOrder = Date.now();

        if (topicId === '__new__') {
          // Create new topic with this article
          const title = article.editorNote && article.editorNote.trim().length > 5
            ? article.editorNote.trim().split(/[.!?\n]/)[0].slice(0, 60)
            : article.title;
          await createTopic(title, [article.id]);
        } else {
          // Add to existing topic
          const topic = topics.find(t => t.id === topicId);
          if (topic) {
            topic.articleIds.push(article.id);
            article.topicId = topicId;
            fetch(`${API}/api/topics`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'add_article', id: topicId, article_id: article.id }),
            }).catch(() => {});
            showToast(`Added to "${truncate(topic.title, 25)}"`);
          }
          render();
        }

        // Send feedback to API
        try {
          await fetch(`${API}/api/feedback`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ articleId: article.id, reaction: 'newsletter_include' }),
          });
        } catch (err) {
          article.state = prevState;
          render();
          showToast('API error — reverted', true);
        }
      }

      // ── Drag and drop ──
      // These are global functions called from inline handlers (needed for dynamic HTML)
      window.handleArticleDragStart = function(e, articleId, fromTopicId) {
        e.dataTransfer.setData('text/plain', JSON.stringify({ articleId, fromTopicId }));
        e.dataTransfer.effectAllowed = 'move';
        e.target.closest('.topic-article-item, .card').style.opacity = '0.4';
        // Highlight all topic bubbles as drop targets
        document.querySelectorAll('.topic-bubble').forEach(b => b.classList.add('drop-target'));
      };

      window.handleTopicDrop = function(e, toTopicId) {
        e.preventDefault();
        document.querySelectorAll('.topic-bubble').forEach(b => {
          b.classList.remove('drag-over', 'drop-target');
        });

        let data;
        try { data = JSON.parse(e.dataTransfer.getData('text/plain')); } catch { return; }
        const { articleId, fromTopicId } = data;

        if (fromTopicId === toTopicId) return; // Same topic, no-op

        // Remove from old topic if it was in one
        if (fromTopicId) {
          const oldTopic = topics.find(t => t.id === fromTopicId);
          if (oldTopic) {
            oldTopic.articleIds = oldTopic.articleIds.filter(id => id !== articleId);
            fetch(`${API}/api/topics`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'remove_article', id: fromTopicId, article_id: articleId }),
            }).catch(() => {});
          }
        }

        // Add to new topic
        const newTopic = topics.find(t => t.id === toTopicId);
        if (newTopic && !newTopic.articleIds.includes(articleId)) {
          newTopic.articleIds.push(articleId);
          const a = articles.find(x => x.id === articleId);
          if (a) a.topicId = toTopicId;
          fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'add_article', id: toTopicId, article_id: articleId }),
          }).catch(() => {});
        }

        render();
        showToast(`Moved to "${truncate(newTopic?.title || '', 25)}"`);
      };

      // Clean up drag styling on dragend
      document.addEventListener('dragend', () => {
        document.querySelectorAll('.topic-bubble').forEach(b => {
          b.classList.remove('drag-over', 'drop-target');
        });
        document.querySelectorAll('[style*="opacity"]').forEach(el => {
          el.style.opacity = '';
        });
      });

      // ── Auto-grouping ──
      // Stop words to ignore when matching
      const STOP = new Set(['this','that','with','from','about','have','been','will',
        'they','their','what','when','which','there','these','than','them','then',
        'into','just','also','more','some','like','your','would','could','should',
        'were','being','does','doing','each','make','made','most','much','very',
        'after','before','only','other','over','such','here','where','every','between']);

      function getKeywords(text) {
        return new Set(
          text.toLowerCase().split(/\W+/)
            .filter(w => w.length > 3 && !STOP.has(w))
        );
      }

      function autoGroupArticle(article) {
        // Build keyword set from article title + note + summary
        const articleText = [article.title, article.editorNote || '', article.summary || ''].join(' ');
        const articleWords = getKeywords(articleText);

        let bestMatch = null;
        let bestScore = 0;

        for (const topic of topics) {
          // Build keyword set from topic title + synthesis + all article titles/notes/summaries
          let topicText = [topic.title, topic.synthesis || ''].join(' ');
          for (const aid of topic.articleIds) {
            const ta = articles.find(a => a.id === aid);
            if (ta) {
              topicText += ' ' + [ta.title, ta.editorNote || '', ta.summary || ''].join(' ');
            }
          }
          const topicWords = getKeywords(topicText);

          const overlap = [...articleWords].filter(w => topicWords.has(w)).length;
          // Score by overlap relative to article word count (prevents big topics from swallowing everything)
          const score = overlap / Math.max(articleWords.size, 1);
          if (overlap >= 2 && score > bestScore && score >= 0.15) {
            bestScore = score;
            bestMatch = topic;
          }
        }

        if (bestMatch) {
          bestMatch.articleIds.push(article.id);
          article.topicId = bestMatch.id;
          fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'add_article', id: bestMatch.id, article_id: article.id }),
          }).catch(() => {});
          showToast(`Grouped into "${truncate(bestMatch.title, 30)}"`);
        } else {
          // Use editor note as topic title if available, otherwise article title
          const topicTitle = article.editorNote && article.editorNote.trim().length > 5
            ? article.editorNote.trim().split(/[.!?\n]/)[0].slice(0, 60)
            : article.title;
          createTopic(topicTitle, [article.id]);
          showToast(`New topic: "${truncate(topicTitle, 30)}"`);
        }
      }

      function cardHTML(a, type, index) {
        const scoreClass = a.score >= 8 ? 'high' : a.score >= 5 ? 'medium' : 'low';
        const tierNames = { 0: 'Top', 1: 'Signal', 2: 'Curated', 3: 'Weekly', 4: 'Community' };
        const focused = a.id === focusedId ? ' focused' : '';
        const rankLabel = type === 'accepted' ? `<span class="card-rank">#${index + 1}</span>` : '';

        let actions = '';
        if (type === 'candidate') {
          actions = `
            <button class="card-btn btn-accept" data-action="accept" title="a">Accept</button>
            <button class="card-btn btn-maybe" data-action="maybe" title="m">Maybe</button>
            <button class="card-btn btn-skip" data-action="skip" title="s">Skip</button>
          `;
        } else if (type === 'maybe') {
          actions = `
            <button class="card-btn btn-accept" data-action="accept" title="a">Accept</button>
            <button class="card-btn btn-undo" data-action="undo" title="u">Back</button>
            <button class="card-btn btn-skip" data-action="skip" title="s">Skip</button>
          `;
        } else if (type === 'accepted') {
          actions = `
            <button class="card-btn btn-maybe" data-action="maybe" title="m">Maybe</button>
            <button class="card-btn btn-undo" data-action="undo" title="u">Remove</button>
          `;
        }

        // Editor note — on accepted cards always visible, on others show if note exists
        const hasNote = a.editorNote && a.editorNote.trim();
        const noteHTML = type === 'accepted' ? `
          <div class="editor-note">
            <textarea class="note-input" data-id="${a.id}"
              placeholder="Your take — why this matters for the digest..."
              rows="2">${escapeHtml(a.editorNote || '')}</textarea>
          </div>
        ` : (type === 'candidate' || type === 'maybe') ? `
          <div class="editor-note collapsed">
            <textarea class="note-input" data-id="${a.id}"
              placeholder="Add a note before accepting..."
              rows="1">${escapeHtml(a.editorNote || '')}</textarea>
          </div>
        ` : '';

        return `
          <div class="card state-${a.state}${focused}" data-id="${a.id}">
            <div class="card-score-strip ${scoreClass}"></div>
            ${rankLabel}
            <div class="card-body">
              <div class="card-title">
                <a href="${a.link}" target="_blank" rel="noopener">${escapeHtml(a.title)}</a>
              </div>
              <div class="card-meta">
                <span class="score ${scoreClass}">${a.score.toFixed(1)}</span>
                <span class="card-source">${escapeHtml(a.source)}</span>
                <span class="tier-badge">${tierNames[a.tier] || 'Tier ' + a.tier}</span>
              </div>
              ${a.summary ? `<div class="card-summary" data-id="${a.id}">${escapeHtml(a.summary)}</div>` : ''}
              ${noteHTML}
            </div>
            <div class="card-actions">${actions}</div>
          </div>
        `;
      }

      function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      function updateCounts() {
        const candidates = getCandidates();
        const accepted = getAccepted();
        const maybes = getMaybes();
        const skipped = getSkipped();

        document.getElementById('count-candidates').textContent = candidates.length;
        document.getElementById('count-accepted').textContent = accepted.length;
        document.getElementById('count-maybe').textContent = maybes.length;
        document.getElementById('count-skipped').textContent = skipped.length;

        document.getElementById('col-count-candidates').textContent = candidates.length;
        document.getElementById('col-count-maybe').textContent = maybes.length;
        document.getElementById('col-count-accepted').textContent = topics.length;

        // Goal progress
        const pct = Math.min((accepted.length / DIGEST_GOAL) * 100, 100);
        const goalFill = document.getElementById('goal-fill');
        goalFill.style.width = pct + '%';
        goalFill.className = 'goal-fill' + (accepted.length > DIGEST_GOAL ? ' over' : '');
        document.getElementById('goal-text').textContent = `${accepted.length} / ${DIGEST_GOAL} stories`;
      }

      function updateFocusUI() {
        document.querySelectorAll('.card.focused').forEach(el => el.classList.remove('focused'));
        if (focusedId) {
          const card = document.querySelector(`.card[data-id="${focusedId}"]`);
          if (card) {
            card.classList.add('focused');
            card.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
          }
        }
      }

      // ── Actions ──
      async function handleAction(id, action) {
        const article = articles.find(a => a.id === id);
        if (!article) return;

        // On accept: show topic picker dropdown
        if (action === 'accept') {
          showTopicPicker(article);
          return;
        }

        const prevState = article.state;
        let newState, reaction;

        switch (action) {
          case 'maybe':
            newState = 'maybe';
            reaction = 'newsletter_maybe';
            break;
          case 'skip':
            newState = 'skipped';
            reaction = 'newsletter_skip';
            break;
          case 'undo':
            newState = 'candidate';
            reaction = 'newsletter_remove';
            break;
        }

        // Remove from topic when moving away from accepted
        if (prevState === 'accepted' && article.topicId) {
          const t = topics.find(x => x.id === article.topicId);
          if (t) t.articleIds = t.articleIds.filter(x => x !== id);
          article.topicId = null;
          fetch(`${API}/api/topics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'remove_article', id: article.topicId, article_id: id }),
          }).catch(() => {});
        }

        article.state = newState;

        advanceFocusAfterAction(id, prevState);
        render();
        showToast(`${truncate(article.title, 40)} → ${newState}`);

        // Send to API
        try {
          await fetch(`${API}/api/feedback`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ articleId: id, reaction }),
          });
        } catch (err) {
          // Revert on failure
          article.state = prevState;
          render();
          showToast('API error — reverted', true);
        }
      }

      function advanceFocusAfterAction(removedId, fromState) {
        const columnMap = {
          candidate: getCandidates,
          maybe: getMaybes,
          accepted: getAccepted,
        };
        const getter = columnMap[fromState];
        if (!getter) return;

        // Get the list before the state change was applied (article already moved)
        const remaining = getter().filter(a => a.id !== removedId);
        if (remaining.length > 0) {
          // Find the article that was below the removed one
          const currentList = articles.filter(a => a.state === fromState).sort((a, b) => b.score - a.score);
          focusedId = remaining[0].id;
        } else {
          focusedId = null;
        }
      }

      // ── Editor notes ──
      async function saveEditorNote(id, note) {
        try {
          await fetch(`${API}/api/feedback`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ articleId: id, reaction: 'editor_note', comment: note }),
          });
        } catch (err) {
          console.warn('Failed to save note:', err);
        }
      }

      // ── Keyboard navigation ──
      document.addEventListener('keydown', (e) => {
        // Don't capture if typing in an input
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
        // Don't capture if preview is open (except Esc)
        if (previewOverlay.classList.contains('visible') && e.key !== 'Escape') return;

        switch (e.key) {
          case 'j': navigateDown(); e.preventDefault(); break;
          case 'k': navigateUp(); e.preventDefault(); break;
          case 'a': doAction('accept'); e.preventDefault(); break;
          case 's': doAction('skip'); e.preventDefault(); break;
          case 'm': doAction('maybe'); e.preventDefault(); break;
          case 'u': doAction('undo'); e.preventDefault(); break;
          case 'e': toggleExpand(); e.preventDefault(); break;
          case 'h': switchColumn('left'); e.preventDefault(); break;
          case 'l': switchColumn('right'); e.preventDefault(); break;
          case 'Escape': closePreview(); break;
        }
      });

      function getCurrentColumnList() {
        switch (focusedColumn) {
          case 'candidates': return getCandidates();
          case 'maybe': return getMaybes();
          case 'accepted': return getAccepted();
          default: return getCandidates();
        }
      }

      function navigateDown() {
        const list = getCurrentColumnList();
        if (list.length === 0) return;
        if (!focusedId) {
          focusedId = list[0].id;
        } else {
          const idx = list.findIndex(a => a.id === focusedId);
          if (idx < list.length - 1) {
            focusedId = list[idx + 1].id;
          }
        }
        updateFocusUI();
      }

      function navigateUp() {
        const list = getCurrentColumnList();
        if (list.length === 0) return;
        if (!focusedId) {
          focusedId = list[0].id;
        } else {
          const idx = list.findIndex(a => a.id === focusedId);
          if (idx > 0) {
            focusedId = list[idx - 1].id;
          }
        }
        updateFocusUI();
      }

      function switchColumn(dir) {
        const cols = ['candidates', 'maybe', 'accepted'];
        const idx = cols.indexOf(focusedColumn);
        let newIdx = dir === 'left' ? idx - 1 : idx + 1;
        newIdx = Math.max(0, Math.min(cols.length - 1, newIdx));
        focusedColumn = cols[newIdx];
        const list = getCurrentColumnList();
        focusedId = list.length > 0 ? list[0].id : null;
        updateFocusUI();
      }

      function doAction(action) {
        if (!focusedId) return;
        handleAction(focusedId, action);
      }

      function toggleExpand() {
        if (!focusedId) return;
        const summaryEl = document.querySelector(`.card-summary[data-id="${focusedId}"]`);
        if (summaryEl) {
          summaryEl.classList.toggle('expanded');
        }
      }

      // ── Fetch stories ──
      // ── New Topic button ──
      document.getElementById('btn-new-topic').addEventListener('click', () => {
        createTopic('', []);
        // Focus the title input of the new topic
        setTimeout(() => {
          const inputs = colAccepted.querySelectorAll('.topic-title-input');
          const last = inputs[inputs.length - 1];
          if (last) last.focus();
        }, 50);
      });

      document.getElementById('btn-fetch').addEventListener('click', async () => {
        const btn = document.getElementById('btn-fetch');
        const status = document.getElementById('fetch-status');
        const statusText = document.getElementById('fetch-status-text');

        btn.disabled = true;
        btn.textContent = 'Fetching...';
        status.style.display = 'inline-flex';

        try {
          await fetch(`${API}/api/pipeline/fetch`, { method: 'POST' });

          // Poll for completion
          const poll = setInterval(async () => {
            try {
              const res = await fetch(`${API}/api/pipeline/status`);
              const data = await res.json();
              statusText.textContent = data.message || 'Working...';

              if (data.state !== 'fetching') {
                clearInterval(poll);
                btn.disabled = false;
                btn.textContent = 'Fetch Stories';
                status.style.display = 'none';
                showToast(data.message || 'Fetch complete');
                loadArticles(); // Reload
              }
            } catch { /* keep polling */ }
          }, 2000);
        } catch (err) {
          btn.disabled = false;
          btn.textContent = 'Fetch Stories';
          status.style.display = 'none';
          showToast('Failed to start fetch', true);
        }
      });

      // ── Preview ──
      // Simple markdown → HTML converter (no library needed)
      function markdownToHtml(md) {
        return md
          // Headers
          .replace(/^## (.+)$/gm, '<h2>$1</h2>')
          .replace(/^# (.+)$/gm, '<h1>$1</h1>')
          // Horizontal rules
          .replace(/^---$/gm, '<hr>')
          // Bold
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          // Italic
          .replace(/\*(.+?)\*/g, '<em>$1</em>')
          // Links
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>')
          // Paragraphs — wrap lines that aren't already tags
          .split('\n\n')
          .map(block => {
            block = block.trim();
            if (!block) return '';
            if (block.startsWith('<h') || block.startsWith('<hr')) return block;
            return `<p>${block.replace(/\n/g, '<br>')}</p>`;
          })
          .join('\n');
      }

      let cachedPreviewMarkdown = null;

      document.getElementById('btn-preview').addEventListener('click', async () => {
        previewOverlay.classList.add('visible');
        document.getElementById('preview-date').textContent = new Date().toLocaleDateString('en-US', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        });

        // Use cached version if available
        if (cachedPreviewMarkdown) {
          document.getElementById('preview-content').innerHTML = markdownToHtml(cachedPreviewMarkdown);
          return;
        }

        document.getElementById('preview-content').innerHTML = '<p style="text-align:center;color:#999;">Generating digest (first run uses Opus, may take 30s)...</p>';

        try {
          const res = await fetch(`${API}/api/digest/preview`);
          const data = await res.json();
          if (data.markdown) {
            cachedPreviewMarkdown = data.markdown;
            document.getElementById('preview-content').innerHTML = markdownToHtml(data.markdown);
          } else {
            document.getElementById('preview-content').innerHTML = '<p style="color:#999;">No content yet. Accept articles into topics first.</p>';
          }
        } catch {
          document.getElementById('preview-content').innerHTML = '<p style="color:#c00;">Could not load preview. Is the API server running?</p>';
        }
      });

      // Regenerate with feedback
      document.getElementById('btn-regenerate').addEventListener('click', async () => {
        const feedback = document.getElementById('preview-feedback-input').value.trim();
        if (!feedback && !cachedPreviewMarkdown) return;

        const currentContent = cachedPreviewMarkdown || '';
        document.getElementById('preview-content').innerHTML = '<p style="text-align:center;color:#999;">Iterating with your feedback (using Sonnet)...</p>';

        try {
          const res = await fetch(`${API}/api/digest/iterate`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              current_draft: currentContent,
              feedback: feedback,
            }),
          });
          const data = await res.json();
          if (data.markdown) {
            cachedPreviewMarkdown = data.markdown;
            document.getElementById('preview-content').innerHTML = markdownToHtml(data.markdown);
            document.getElementById('preview-feedback-input').value = '';
            showToast('Draft updated');
          }
        } catch {
          document.getElementById('preview-content').innerHTML = markdownToHtml(currentContent);
          showToast('Iteration failed', true);
        }
      });

      document.getElementById('btn-close-preview').addEventListener('click', closePreview);
      document.getElementById('btn-publish-from-preview').addEventListener('click', () => {
        closePreview();
        document.getElementById('btn-publish').click();
      });
      previewOverlay.addEventListener('click', (e) => {
        if (e.target === previewOverlay) closePreview();
      });

      function closePreview() {
        previewOverlay.classList.remove('visible');
      }

      // ── Publish ──
      document.getElementById('btn-publish').addEventListener('click', async () => {
        if (!cachedPreviewMarkdown) {
          showToast('Preview first, then publish', true);
          return;
        }

        if (!confirm('Publish this digest to the website?')) return;

        const btn = document.getElementById('btn-publish');
        btn.disabled = true;
        btn.textContent = 'Publishing...';

        try {
          const res = await fetch(`${API}/api/digest/publish`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ markdown: cachedPreviewMarkdown }),
          });
          const data = await res.json();

          if (data.success) {
            showToast(`Published! ${data.date}`);
          } else {
            showToast(data.message || 'Publish failed', true);
          }
        } catch {
          showToast('Publish failed — API error', true);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Publish';
        }
      });

      // ── Toast ──
      let toastTimeout;
      function showToast(msg, isError) {
        toast.textContent = msg;
        toast.style.borderColor = isError ? 'var(--red)' : 'var(--border)';
        toast.classList.add('visible');
        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => toast.classList.remove('visible'), 2500);
      }

      function truncate(str, len) {
        return str.length > len ? str.slice(0, len) + '...' : str;
      }
    </script>
  </body>
</html>
